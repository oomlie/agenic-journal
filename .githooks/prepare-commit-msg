#!/bin/bash
COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2
if [ -n "$COMMIT_SOURCE" ]; then exit 0; fi
STAGED_FILES=$(git diff --cached --name-only)
JOURNAL_FILES=$(echo "$STAGED_FILES" | grep -E '^[0-9]{4}/[0-9]{2}-[a-z]+/[0-9]{4}-[0-9]{2}-[0-9]{2}\.md$' || true)
if [ -z "$JOURNAL_FILES" ]; then exit 0; fi
TIMESTAMP=$(date '+%Y-%m-%d %H:%M')
TIME_OF_DAY=$(date '+%H')
if [ "$TIME_OF_DAY" -lt 12 ]; then PERIOD="morning"
elif [ "$TIME_OF_DAY" -lt 17 ]; then PERIOD="afternoon"
else PERIOD="evening"; fi
ENTRY_DATE=$(echo "$JOURNAL_FILES" | head -n1 | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}')
FILE_COUNT=$(echo "$JOURNAL_FILES" | wc -l | tr -d ' ')
if [ "$FILE_COUNT" -eq 1 ]; then
    echo "$ENTRY_DATE -- journal update ($PERIOD, $TIMESTAMP)" > "$COMMIT_MSG_FILE"
else
    echo "$ENTRY_DATE +$FILE_COUNT entries -- journal update ($PERIOD, $TIMESTAMP)" > "$COMMIT_MSG_FILE"
fi
COMPLETED=$(git diff --cached | grep -cE '^\+.*\[x\]' || true)
ADDED=$(git diff --cached | grep -cE '^\+.*\[ \]' || true)
if [ "$COMPLETED" -gt 0 ] || [ "$ADDED" -gt 0 ]; then
    echo "" >> "$COMMIT_MSG_FILE"
    echo "Tasks: $COMPLETED completed, $ADDED added" >> "$COMMIT_MSG_FILE"
fi
