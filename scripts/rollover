#!/bin/bash
set -euo pipefail
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -z "$REPO_ROOT" ]; then echo "Error: Not inside a Git repository."; exit 1; fi

if [ -n "${1:-}" ]; then
    SOURCE_DATE="$1"
    TARGET_DATE=$(date -d "$SOURCE_DATE + 1 day" '+%Y-%m-%d' 2>/dev/null)
else
    TARGET_DATE=$(date '+%Y-%m-%d')
    SOURCE_DATE=$(date -d "$TARGET_DATE - 1 day" '+%Y-%m-%d' 2>/dev/null)
fi

resolve_path() {
    local d="$1"
    local y=$(echo "$d" | cut -d'-' -f1)
    local m=$(echo "$d" | cut -d'-' -f2)
    local month_name=$(date -d "$d" '+%B' 2>/dev/null)
    if [ -z "$month_name" ]; then
        case "$m" in
            01) month_name="January" ;; 02) month_name="February" ;; 03) month_name="March" ;;
            04) month_name="April" ;; 05) month_name="May" ;; 06) month_name="June" ;;
            07) month_name="July" ;; 08) month_name="August" ;; 09) month_name="September" ;;
            10) month_name="October" ;; 11) month_name="November" ;; 12) month_name="December" ;;
        esac
    fi
    echo "$REPO_ROOT/$y/$m-$(echo "$month_name" | tr '[:upper:]' '[:lower:]')/$d.md"
}

SOURCE_FILE=$(resolve_path "$SOURCE_DATE")
TARGET_FILE=$(resolve_path "$TARGET_DATE")

if [ ! -f "$SOURCE_FILE" ]; then
    echo "No entry found for $SOURCE_DATE. Nothing to roll over."
    exit 0
fi

if [ ! -f "$TARGET_FILE" ]; then
    "$REPO_ROOT/scripts/new-day" "$TARGET_DATE" >/dev/null
fi

UNCHECKED=$(sed -n '/^### Top 3 Priorities/,/^---$/p' "$SOURCE_FILE" | grep -E '^[0-9]+\. \[ \]' || true)

if [ -z "$UNCHECKED" ]; then
    echo "No unchecked tasks in $SOURCE_DATE. You're all caught up!"
    exit 0
fi

ROLLOVER_BLOCK="### Rolled Over from $SOURCE_DATE"
while IFS= read -r line; do
    task_text=$(echo "$line" | sed -E 's/^[0-9]+\. \[ \] //')
    ROLLOVER_BLOCK="$ROLLOVER_BLOCK
- [ ] $task_text"
done <<< "$UNCHECKED"

python3 << PYEOF
import sys

source_file = "$SOURCE_FILE"
target_file = "$TARGET_FILE"
rollover_block = """$ROLLOVER_BLOCK"""

with open(target_file, 'r') as f:
    lines = f.readlines()

insert_after = -1
for i, line in enumerate(lines):
    if line.strip() == '### Top 3 Priorities':
        insert_after = i
        break

if insert_after >= 0:
    insert_lines = ['\n'] + [l + '\n' for l in rollover_block.split('\n')] + ['\n']
    new_lines = lines[:insert_after+1] + insert_lines + lines[insert_after+1:]
    with open(target_file, 'w') as f:
        f.writelines(new_lines)
else:
    with open(target_file, 'a') as f:
        f.write('\n' + rollover_block + '\n')
PYEOF

sed -i 's/^\([0-9]*\. \)\[ \]/\1[>]/g' "$SOURCE_FILE"
git add "$SOURCE_FILE" "$TARGET_FILE"

NUM_TASKS=$(echo "$UNCHECKED" | wc -l | tr -d ' ')
cat <<EOOUT
+---------------------------------------------------+
|              TASKS ROLLED OVER                     |
+---------------------------------------------------+
|  $NUM_TASKS task(s) from $SOURCE_DATE -> $TARGET_DATE  |
|                                                   |
|  Run 'git commit' when ready.                     |
|  Hooks will auto-message it.                      |
+---------------------------------------------------+
EOOUT
