#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

REPO_ROOT=$(journal_require_repo_root)

MESSAGE=""; TARGET_DATE=""; NO_COMMIT=false; TAG=""

while [ $# -gt 0 ]; do
    case "$1" in
        -d|--date) TARGET_DATE="$2"; shift 2;;
        -n|--no-commit) NO_COMMIT=true; shift;;
        -t|--tag) TAG="$2"; shift 2;;
        -*) echo "Unknown flag: $1" >&2; exit 1;;
        *)
            if [ -z "$MESSAGE" ]; then MESSAGE="$1"
            else MESSAGE="$MESSAGE $1"; fi
            shift;;
    esac
done

if [ -z "$MESSAGE" ]; then
    echo "Usage: log \"your note here\" [-d YYYY-MM-DD] [-t tag] [-n]" >&2
    exit 1
fi

if [ -n "$TARGET_DATE" ]; then
    ENTRY_DATE="$TARGET_DATE"
    journal_validate_date "$ENTRY_DATE"
else
    ENTRY_DATE=$(date '+%Y-%m-%d')
fi

ENTRY_FILE=$(journal_entry_path "$REPO_ROOT" "$ENTRY_DATE")

if [ ! -f "$ENTRY_FILE" ]; then
    "$SCRIPT_DIR/new-day" "$ENTRY_DATE" >/dev/null
fi

TIMESTAMP=$(date '+%H:%M')
LOG_LINE="- $TIMESTAMP -- $MESSAGE"
[ -n "$TAG" ] && LOG_LINE="$LOG_LINE #$TAG"

# Use journal_insert_after_line for both insertion paths (bug b fix)
if grep -qE "$JOURNAL_LOG_LINE_REGEX" "$ENTRY_FILE"; then
    LAST_LOG_LINE=$(grep -nE "$JOURNAL_LOG_LINE_REGEX" "$ENTRY_FILE" | tail -n1 | cut -d':' -f1)
    journal_insert_after_line "$ENTRY_FILE" "$LAST_LOG_LINE" "$LOG_LINE"
else
    LOG_HEADER_LINE=$(grep -n '^## Log$' "$ENTRY_FILE" | head -n1 | cut -d':' -f1)
    if [ -n "$LOG_HEADER_LINE" ]; then
        journal_insert_after_line "$ENTRY_FILE" "$LOG_HEADER_LINE" "$LOG_LINE"
    else
        echo "" >> "$ENTRY_FILE"
        echo "$LOG_LINE" >> "$ENTRY_FILE"
    fi
fi

git add "$ENTRY_FILE"

if [ "$NO_COMMIT" = true ]; then
    cat <<EOOUT
+---------------------------------------------------+
|                     LOGGED                         |
+---------------------------------------------------+
|  $LOG_LINE
|                                                   |
|  (staged, not committed)                          |
+---------------------------------------------------+
EOOUT
else
    SHORT_MSG=$(echo "$MESSAGE" | cut -c1-50)
    git commit -m "[$ENTRY_DATE $TIMESTAMP] $SHORT_MSG" --quiet
    cat <<EOOUT
+---------------------------------------------------+
|                     LOGGED                         |
+---------------------------------------------------+
|  $LOG_LINE
+---------------------------------------------------+
EOOUT
fi
