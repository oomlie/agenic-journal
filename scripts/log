#!/bin/bash
#
# log
# Quick one-liner to append a timestamped note to today's journal entry.
#
# Usage:
#   ./scripts/log "got lunch at panda express"
#   ./scripts/log -m "meeting notes: discussed q3 roadmap"
#
# Flags:
#   -m, --message   The log message (optional, defaults to positional arg)
#   -d, --date      Target a specific date: YYYY-MM-DD (defaults to today)
#   -n, --no-commit Append without committing (just stage)
#   -t, --tag       Add a tag: #win #struggle #adhd #deepwork #health
#

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)

if [ -z "$REPO_ROOT" ]; then
    echo "Error: Not inside a Git repository."
    exit 1
fi

# --- Parse args ---

MESSAGE=""
TARGET_DATE=""
NO_COMMIT=false
TAG=""

while [ $# -gt 0 ]; do
    case "$1" in
        -m|--message)
            MESSAGE="$2"
            shift 2
            ;;
        -d|--date)
            TARGET_DATE="$2"
            shift 2
            ;;
        -n|--no-commit)
            NO_COMMIT=true
            shift
            ;;
        -t|--tag)
            TAG="$2"
            shift 2
            ;;
        -*)
            echo "Unknown flag: $1"
            echo "Usage: ./scripts/log [-m message] [-d YYYY-MM-DD] [-n] [-t tag]"
            exit 1
            ;;
        *)
            if [ -z "$MESSAGE" ]; then
                MESSAGE="$1"
            else
                MESSAGE="$MESSAGE $1"
            fi
            shift
            ;;
    esac
done

if [ -z "$MESSAGE" ]; then
    echo "Usage: ./scripts.log \"your note here\""
    echo "       ./scripts/log -m \"your note\" -t win"
    exit 1
fi

# --- Determine date and file path ---

if [ -n "$TARGET_DATE" ]; then
    ENTRY_DATE="$TARGET_DATE"
else
    ENTRY_DATE=$(date '+%Y-%m-%d')
fi

YEAR=$(echo "$ENTRY_DATE" | cut -d'-' -f1)
MONTH_NUM=$(echo "$ENTRY_DATE" | cut -d'-' -f2)

# Month name (cross-platform)
MONTH_NAME=$(date -d "$ENTRY_DATE" '+%B' 2>/dev/null || date -j -f '%Y-%m-%d' "$ENTRY_DATE" '+%B' 2>/dev/null)
if [ -z "$MONTH_NAME" ]; then
    case "$MONTH_NUM" in
        01) MONTH_NAME="January" ;; 02) MONTH_NAME="February" ;; 03) MONTH_NAME="March" ;;
        04) MONTH_NAME="April" ;; 05) MONTH_NAME="May" ;; 06) MONTH_NAME="June" ;;
        07) MONTH_NAME="July" ;; 08) MONTH_NAME="August" ;; 09) MONTH_NAME="September" ;;
        10) MONTH_NAME="October" ;; 11) MONTH_NAME="November" ;; 12) MONTH_NAME="December" ;;
    esac
fi

MONTH_DIR="$REPO_ROOT/$YEAR/$MONTH_NUM-$(echo "$MONTH_NAME" | tr '[:upper:]' '[:lower:]')"
ENTRY_FILE="$MONTH_DIR/$ENTRY_DATE.md"

# --- Create entry if it doesn't exist ---

if [ ! -f "$ENTRY_FILE" ]; then
    echo "No entry for $ENTRY_DATE. Creating one..."
    "$REPO_ROOT/scripts/new-day" "$ENTRY_DATE" >/dev/null
fi

# --- Build the log line ---

TIMESTAMP=$(date '+%H:%M')
LOG_LINE="- $TIMESTAMP — $MESSAGE"

if [ -n "$TAG" ]; then
    LOG_LINE="$LOG_LINE #$TAG"
fi

# --- Append to the Log section ---

# Insert the log line before the "---" that follows "## Log"
# Strategy: find the Log section and append after the last existing log entry
# Simple approach: use sed to add after the "## Log" header or after existing log lines

# Check if there's already a log entry (lines starting with "- HH:MM")
if grep -qE '^- [0-9]{2}:[0-9]{2} —' "$ENTRY_FILE"; then
    # Append after the last existing log line
    LAST_LOG_LINE=$(grep -nE '^- [0-9]{2}:[0-9]{2} —' "$ENTRY_FILE" | tail -n1 | cut -d':' -f1)
    sed -i "" "${LAST_LOG_LINE}a\\
$LOG_LINE" "$ENTRY_FILE" 2>/dev/null || sed -i "${LAST_LOG_LINE}a\\ $LOG_LINE" "$ENTRY_FILE"
else
    # No existing log lines — add right after "## Log"
    LOG_HEADER_LINE=$(grep -n '^## Log$' "$ENTRY_FILE" | head -n1 | cut -d':' -f1)
    if [ -n "$LOG_HEADER_LINE" ]; then
        sed -i "" "${LOG_HEADER_LINE}a\\
\\
$LOG_LINE" "$ENTRY_FILE" 2>/dev/null || sed -i "${LOG_HEADER_LINE}a\\ \\$LOG_LINE" "$ENTRY_FILE"
    else
        # Fallback: just append to file
        echo "" >> "$ENTRY_FILE"
        echo "$LOG_LINE" >> "$ENTRY_FILE"
    fi
fi

# --- Stage (and optionally commit) ---

git add "$ENTRY_FILE"

if [ "$NO_COMMIT" = true ]; then
    echo "Logged: $LOG_LINE"
    echo "(staged, not committed — commit manually when ready)"
else
    SHORT_MSG=$(echo "$MESSAGE" | cut -c1-50)
    git commit -m "[$ENTRY_DATE $TIMESTAMP] $SHORT_MSG" --quiet
    echo "Logged: $LOG_LINE"
fi
