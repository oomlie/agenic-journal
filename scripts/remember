#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

REPO_ROOT=$(journal_require_repo_root)

MIN_DAYS=30; MAX_DAYS=90

if [ "${1:-}" = "--today" ] || [ "${1:-}" = "-t" ]; then
    TARGET_DATE=$(journal_add_days "$(date '+%Y-%m-%d')" -365)
    echo "This day last year: $TARGET_DATE"; echo ""
else
    if [ $# -ge 2 ]; then MIN_DAYS=$1; MAX_DAYS=$2; fi
    SPAN=$((MAX_DAYS - MIN_DAYS))
    RANDOM_DAYS=$((MIN_DAYS + RANDOM % (SPAN + 1)))
    TARGET_DATE=$(journal_add_days "$(date '+%Y-%m-%d')" "-$RANDOM_DAYS")
fi

ENTRY_FILE=$(journal_entry_path "$REPO_ROOT" "$TARGET_DATE")
TODAY_EPOCH=$(journal_epoch "$(date '+%Y-%m-%d')")
TARGET_EPOCH=$(journal_epoch "$TARGET_DATE")
DAYS_AGO=$(( (TODAY_EPOCH - TARGET_EPOCH) / 86400 ))

HEADER="+---------------------------------------------------+"

if [ -f "$ENTRY_FILE" ]; then
    echo "$HEADER"
    printf "|         MEMORY FROM %3s DAYS AGO                |\n" "$DAYS_AGO"
    printf "|              %s                  |\n" "$TARGET_DATE"
    echo "$HEADER"; echo ""; cat "$ENTRY_FILE"; echo ""; echo "$HEADER"
else
    echo "No journal entry found for $TARGET_DATE ($DAYS_AGO days ago)."
    echo ""; echo "Searching for nearby entries..."
    for offset in $(seq 1 7); do
        nearby=$(journal_add_days "$TARGET_DATE" "-$offset")
        nearby_file=$(journal_entry_path "$REPO_ROOT" "$nearby")
        if [ -f "$nearby_file" ]; then
            echo ""; echo "$HEADER"
            printf "|   CLOSEST ENTRY FOUND: %s DAYS AGO              |\n" "$offset"
            printf "|              %s                  |\n" "$nearby"
            echo "$HEADER"; echo ""; cat "$nearby_file"; echo ""; echo "$HEADER"
            break
        fi
    done
fi
