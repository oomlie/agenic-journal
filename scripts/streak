#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

REPO_ROOT=$(journal_require_repo_root)

MODE="all"
if [ "${1:-}" = "--month" ] || [ "${1:-}" = "-m" ]; then MODE="month"
elif [ "${1:-}" = "--year" ] || [ "${1:-}" = "-y" ]; then MODE="year"; fi

ALL_DATES=$(find "$REPO_ROOT" -type f -name '*.md' | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}\.md$' | sed 's/\.md$//' | sort)
if [ -z "$ALL_DATES" ]; then echo "No journal entries found yet. Start journaling!"; exit 0; fi

if [ "$MODE" = "month" ]; then
    CURRENT_MONTH=$(date '+%Y-%m')
    DATES=$(echo "$ALL_DATES" | grep "^$CURRENT_MONTH" || true)
    LABEL="This Month"
elif [ "$MODE" = "year" ]; then
    CURRENT_YEAR=$(date '+%Y')
    DATES=$(echo "$ALL_DATES" | grep "^$CURRENT_YEAR" || true)
    LABEL="This Year"
else
    DATES="$ALL_DATES"
    LABEL="All Time"
fi

if [ -z "$DATES" ]; then echo "No entries for $LABEL."; exit 0; fi

TOTAL_ENTRIES=$(echo "$DATES" | wc -l | tr -d ' ')
FIRST_DATE=$(echo "$DATES" | head -n1)

TODAY=$(date '+%Y-%m-%d')
YESTERDAY=$(journal_add_days "$TODAY" -1)

CURRENT_STREAK=0; CHECK_DATE="$TODAY"
if echo "$DATES" | grep -qx "$TODAY"; then CURRENT_STREAK=1
elif echo "$DATES" | grep -qx "$YESTERDAY"; then CURRENT_STREAK=1; CHECK_DATE="$YESTERDAY"
else CURRENT_STREAK=0; fi

if [ $CURRENT_STREAK -gt 0 ]; then
    while true; do
        PREV=$(journal_add_days "$CHECK_DATE" -1)
        if echo "$DATES" | grep -qx "$PREV"; then
            CURRENT_STREAK=$((CURRENT_STREAK + 1)); CHECK_DATE="$PREV"
        else break; fi
    done
fi

LONGEST_STREAK=0; CURRENT_RUN=0; PREV_EPOCH=0
for d in $(echo "$DATES" | sort); do
    THIS_EPOCH=$(journal_epoch "$d")
    if [ $PREV_EPOCH -eq 0 ]; then CURRENT_RUN=1
    else
        DIFF=$(( (THIS_EPOCH - PREV_EPOCH) / 86400 ))
        if [ $DIFF -eq 1 ]; then CURRENT_RUN=$((CURRENT_RUN + 1))
        else
            [ $CURRENT_RUN -gt $LONGEST_STREAK ] && LONGEST_STREAK=$CURRENT_RUN
            CURRENT_RUN=1
        fi
    fi
    PREV_EPOCH=$THIS_EPOCH
done
[ $CURRENT_RUN -gt $LONGEST_STREAK ] && LONGEST_STREAK=$CURRENT_RUN

DOW=$(journal_day_of_week "$(date '+%Y-%m-%d')")
DAYS_BACK=$((DOW - 1))
WEEK_START=$(journal_add_days "$(date '+%Y-%m-%d')" "-$DAYS_BACK")
THIS_WEEK_COUNT=0
for i in $(seq 0 6); do
    CHECK=$(journal_add_days "$WEEK_START" $i)
    echo "$DATES" | grep -qx "$CHECK" && THIS_WEEK_COUNT=$((THIS_WEEK_COUNT + 1))
done

FIRE_7=""; FIRE_30=""; FIRE_100=""
[ $CURRENT_STREAK -ge 7 ] && FIRE_7="[*]"
[ $CURRENT_STREAK -ge 30 ] && FIRE_30="[*]"
[ $CURRENT_STREAK -ge 100 ] && FIRE_100="[*]"

if [ $CURRENT_STREAK -eq 0 ]; then FIRE_ART=$(cat <<'EOF'
        (    )
        )  (
      .'    '.
     /        \
    |          |
     \  ~  ~  /
      '.____.'
EOF
)
elif [ $CURRENT_STREAK -lt 7 ]; then FIRE_ART=$(cat <<'EOF'
         )
        (  )
       .'  '.
      / ~  ~ \
     |        |
      \      /
       '....'
      /      \
     '________'
EOF
)
elif [ $CURRENT_STREAK -lt 30 ]; then FIRE_ART=$(cat <<'EOF'
       .-(   )-.
      /         \
     |   ~   ~   |
     |           |
      \  .---.  /
       '-/   \-'
        /     \
       '-------'
      /         \
     '___________'
EOF
)
else FIRE_ART=$(cat <<'EOF'
         (    )
         )  ( (
       .'   '. '.
      /  ~  ~  \
     |          |
     |  *    *  |
      \  \~~/  /
       '-.  .-'
      .-'    '-.
     /  .----.  \
    /  /      \  \
   '  '________'  '
   '______________'
EOF
); fi

if [ "$MODE" = "all" ]; then cat <<EOF
$FIRE_ART
+---------------------------------------------------+
|                 JOURNAL STREAKS                    |
+---------------------------------------------------+
|  $LABEL                                           |
|                                                   |
|  Current Streak : $CURRENT_STREAK days
|  Longest Streak : $LONGEST_STREAK days
|  Total Entries  : $TOTAL_ENTRIES
|  First Entry    : $FIRST_DATE
|                                                   |
|  Milestones:                                      |
|    7-day streak  $FIRE_7                          |
|    30-day streak $FIRE_30                         |
|    100-day streak $FIRE_100                       |
|                                                   |
|  This Week      : $THIS_WEEK_COUNT / 7 days
+---------------------------------------------------+
EOF
else cat <<EOF
$FIRE_ART
+---------------------------------------------------+
|                 JOURNAL STREAKS                    |
+---------------------------------------------------+
|  $LABEL                                           |
|                                                   |
|  Current Streak : $CURRENT_STREAK days
|  Total Entries  : $TOTAL_ENTRIES
|  This Week      : $THIS_WEEK_COUNT / 7 days
+---------------------------------------------------+
EOF
fi
