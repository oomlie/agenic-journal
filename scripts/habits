#!/bin/bash
#
# habits
# Tallies habit tracker checkboxes from daily entries for a given month.
# Outputs a markdown table with streaks and completion rates.
#
# Usage:
#   ./scripts/habits              # Current month
#   ./scripts/habits 2026 07      # Specific year and month
#   ./scripts/habits --fill       # Auto-fill the weekly review habit table
#

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)

if [ -z "$REPO_ROOT" ]; then
    echo "Error: Not inside a Git repository."
    exit 1
fi

FILL_REVIEW=false

# --- Parse args ---

if [ "${1:-}" = "--fill" ] || [ "${1:-}" = "-f" ]; then
    FILL_REVIEW=true
    # Default to current month for fill mode
    YEAR=$(date '+%Y')
    MONTH=$(date '+%m')
elif [ $# -ge 2 ]; then
    YEAR=$1
    MONTH=$2
else
    YEAR=$(date '+%Y')
    MONTH=$(date '+%m')
fi

# Validate month
if ! echo "$MONTH" | grep -qE '^[0-9]{2}$'; then
    MONTH=$(printf "%02d" "$MONTH")
fi

month_name=$(date -d "$YEAR-$MONTH-01" '+%B' 2>/dev/null || date -j -f '%Y-%m-%d' "$YEAR-$MONTH-01" '+%B' 2>/dev/null)
if [ -z "$month_name" ]; then
    case "$MONTH" in
        01) month_name="January" ;; 02) month_name="February" ;; 03) month_name="March" ;;
        04) month_name="April" ;; 05) month_name="May" ;; 06) month_name="June" ;;
        07) month_name="July" ;; 08) month_name="August" ;; 09) month_name="September" ;;
        10) month_name="October" ;; 11) month_name="November" ;; 12) month_name="December" ;;
    esac
fi

MONTH_DIR="$REPO_ROOT/$YEAR/$MONTH-$(echo "$month_name" | tr '[:upper:]' '[:lower:]')"

if [ ! -d "$MONTH_DIR" ]; then
    echo "No journal entries found for $month_name $YEAR."
    exit 0
fi

# --- Define habits to track ---
# These map to the habit names in the daily template's ## Habits section

HABIT_NAMES=("Exercise" "Read" "Meditate" "Deep Work" "Sleep 8h")
HABIT_KEYS=("exercise" "read" "meditate" "deep work" "sleep")

# --- Scan entries ---

DAYS_IN_MONTH=$(date -d "$YEAR-$MONTH-01 + 1 month - 1 day" '+%d' 2>/dev/null || date -v+1m -v-1d -j -f '%Y-%m-%d' "$YEAR-$MONTH-01" '+%d' 2>/dev/null)

declare -A HABIT_COUNTS
declare -A HABIT_STREAKS
declare -A HABIT_CURRENT_STREAK

for h in "${HABIT_NAMES[@]}"; do
    HABIT_COUNTS[$h]=0
    HABIT_STREAKS[$h]=0
    HABIT_CURRENT_STREAK[$h]=0
done

PREV_DAY_CHECKED=()
for h in "${HABIT_NAMES[@]}"; do
    PREV_DAY_CHECKED+=("false")
done

DAY_CHECKS=()

for day in $(seq -w 1 $DAYS_IN_MONTH); do
    ENTRY_FILE="$MONTH_DIR/$YEAR-$MONTH-$day.md"
    day_checks_row=""

    if [ -f "$ENTRY_FILE" ]; then
        # Extract the Habits section
        habits_section=$(sed -n '/^## Habits/,/^## /p' "$ENTRY_FILE" | head -n -1 || true)

        idx=0
        for h in "${HABIT_NAMES[@]}"; do
            key="${HABIT_KEYS[$idx]}"
            # Check if this habit is checked in the entry
            # Match: "- [x] Exercise" or "- [X] Read" etc (case insensitive)
            if echo "$habits_section" | grep -qiE "^- \[[xX]\] +$h" 2>/dev/null; then
                day_checks_row="${day_checks_row}| ✅ "
                HABIT_COUNTS[$h]=$((${HABIT_COUNTS[$h]} + 1))

                # Streak logic
                HABIT_CURRENT_STREAK[$h]=$((${HABIT_CURRENT_STREAK[$h]} + 1))
                if [ ${HABIT_CURRENT_STREAK[$h]} -gt ${HABIT_STREAKS[$h]} ]; then
                    HABIT_STREAKS[$h]=${HABIT_CURRENT_STREAK[$h]}
                fi
            else
                day_checks_row="${day_checks_row}|    "
                HABIT_CURRENT_STREAK[$h]=0
            fi
            idx=$((idx + 1))
        done
    else
        # No entry for this day
        for h in "${HABIT_NAMES[@]}"; do
            day_checks_row="${day_checks_row}|    "
        done
        idx=0
        for h in "${HABIT_NAMES[@]}"; do
            HABIT_CURRENT_STREAK[$h]=0
            idx=$((idx + 1))
        done
    fi

    DAY_CHECKS+=("$day_checks_row")
done

# --- Build output ---

OUTPUT="# Habit Tracker — $month_name $YEAR

| Habit"
for day in $(seq -w 1 $DAYS_IN_MONTH); do
    day_num=$(echo "$day" | sed 's/^0//')
    OUTPUT="$OUTPUT | $day_num"
done
OUTPUT="$OUTPUT | Total | Streak |"

OUTPUT="$OUTPUT
|-------"
for day in $(seq 1 $DAYS_IN_MONTH); do
    OUTPUT="$OUTPUT|------"
done
OUTPUT="$OUTPUT|-------|--------|"

idx=0
for h in "${HABIT_NAMES[@]}"; do
    row="| $h"
    for check in "${DAY_CHECKS[@]}"; do
        # Extract the check for this habit index
        habit_check=$(echo "$check" | cut -d'|' -f$((idx + 2)))
        row="$row$habit_check|"
    done
    count=${HABIT_COUNTS[$h]}
    streak=${HABIT_STREAKS[$h]}
    row="$row $count | $streak |"
    OUTPUT="$OUTPUT
$row"
    idx=$((idx + 1))
done

OUTPUT="$OUTPUT

*Auto-generated from daily journal entries.*
"

# --- Output or fill review ---

if [ "$FILL_REVIEW" = true ]; then
    # Find the most recent weekly review
    REVIEW_DIR="$REPO_ROOT/reviews"
    if [ -d "$REVIEW_DIR" ]; then
        LATEST_REVIEW=$(ls -1t "$REVIEW_DIR"/*.md 2>/dev/null | head -n1 || true)
        if [ -n "$LATEST_REVIEW" ]; then
            echo "Filling habit table in: $LATEST_REVIEW"
            # TODO: Implement actual table replacement in review
            # For now, output the habit data
            echo "$OUTPUT"
            git add "$LATEST_REVIEW" 2>/dev/null || true
        else
            echo "No weekly review found. Outputting habit data:"
            echo "$OUTPUT"
        fi
    else
        echo "No reviews directory. Outputting habit data:"
        echo "$OUTPUT"
    fi
else
    HABIT_FILE="$REPO_ROOT/$YEAR/$MONTH-$(echo "$month_name" | tr '[:upper:]' '[:lower:]')/habits.md"
    echo "$OUTPUT" > "$HABIT_FILE"
    git add "$HABIT_FILE" 2>/dev/null || true
    echo "Habit tracker saved: $HABIT_FILE"
fi

echo ""
echo "Summary for $month_name $YEAR:"
for h in "${HABIT_NAMES[@]}"; do
    count=${HABIT_COUNTS[$h]}
    streak=${HABIT_STREAKS[$h]}
    echo "  $h: $count days, best streak: $streak"
done
