#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

REPO_ROOT=$(journal_require_repo_root)

FILL_REVIEW=false

if [ "${1:-}" = "--fill" ] || [ "${1:-}" = "-f" ]; then
    FILL_REVIEW=true
    YEAR=$(date '+%Y'); MONTH=$(date '+%m')
elif [ $# -ge 2 ]; then
    YEAR=$1; MONTH=$2
else
    YEAR=$(date '+%Y'); MONTH=$(date '+%m')
fi

if ! echo "$MONTH" | grep -qE '^[0-9]{2}$'; then
    MONTH=$(printf "%02d" "$MONTH")
fi

MONTH_DIR=$(journal_month_dir "$REPO_ROOT" "$YEAR" "$MONTH")
if [ ! -d "$MONTH_DIR" ]; then
    echo "No journal entries found for month $YEAR-$MONTH."
    exit 0
fi

HABIT_NAMES=("Exercise" "Read" "Meditate" "Deep Work" "Sleep 8h")
DAYS_IN_MONTH=$(journal_days_in_month "$YEAR" "$MONTH")

declare -A HABIT_COUNTS
declare -A HABIT_STREAKS
declare -A HABIT_CURRENT_STREAK
for h in "${HABIT_NAMES[@]}"; do
    HABIT_COUNTS[$h]=0
    HABIT_STREAKS[$h]=0
    HABIT_CURRENT_STREAK[$h]=0
done

# Bug (c) fix: seed streaks by walking backward from month start
PREV_DATE=$(journal_add_days "$YEAR-$MONTH-01" -1)
SEED_WALK=0
while [ "$SEED_WALK" -lt 60 ]; do
    PREV_FILE=$(journal_entry_path "$REPO_ROOT" "$PREV_DATE")
    if [ -f "$PREV_FILE" ]; then
        habits_section=$(sed -n '/^## Habits/,/^## /p' "$PREV_FILE" | head -n -1 || true)
        for h in "${HABIT_NAMES[@]}"; do
            if echo "$habits_section" | grep -qiE "^- \[[xX]\] +$h" 2>/dev/null; then
                HABIT_CURRENT_STREAK[$h]=$((${HABIT_CURRENT_STREAK[$h]} + 1))
            else
                HABIT_CURRENT_STREAK[$h]=0
            fi
        done
    else
        break
    fi
    PREV_DATE=$(journal_add_days "$PREV_DATE" -1)
    SEED_WALK=$((SEED_WALK + 1))
done

DAY_CHECKS=()

for day in $(seq -w 1 "$DAYS_IN_MONTH"); do
    ENTRY_FILE="$MONTH_DIR/$YEAR-$MONTH-$day.md"
    day_checks_row=""
    if [ -f "$ENTRY_FILE" ]; then
        habits_section=$(sed -n '/^## Habits/,/^## /p' "$ENTRY_FILE" | head -n -1 || true)
        for h in "${HABIT_NAMES[@]}"; do
            if echo "$habits_section" | grep -qiE "^- \[[xX]\] +$h" 2>/dev/null; then
                day_checks_row="${day_checks_row}| [x]"
                HABIT_COUNTS[$h]=$((${HABIT_COUNTS[$h]} + 1))
                HABIT_CURRENT_STREAK[$h]=$((${HABIT_CURRENT_STREAK[$h]} + 1))
                if [ "${HABIT_CURRENT_STREAK[$h]}" -gt "${HABIT_STREAKS[$h]}" ]; then
                    HABIT_STREAKS[$h]=${HABIT_CURRENT_STREAK[$h]}
                fi
            else
                day_checks_row="${day_checks_row}| [ ]"
                HABIT_CURRENT_STREAK[$h]=0
            fi
        done
    else
        for h in "${HABIT_NAMES[@]}"; do
            day_checks_row="${day_checks_row}| [ ]"
            HABIT_CURRENT_STREAK[$h]=0
        done
    fi
    DAY_CHECKS+=("$day_checks_row")
done

# Build monthly table
MONTHLY_TABLE="# Habit Tracker -- $YEAR-$MONTH

| Habit"
for day in $(seq -w 1 "$DAYS_IN_MONTH"); do
    day_num="${day#0}"
    MONTHLY_TABLE="$MONTHLY_TABLE | $day_num"
done
MONTHLY_TABLE="$MONTHLY_TABLE | Total | Streak |"

MONTHLY_TABLE="$MONTHLY_TABLE
|-------"
for day in $(seq 1 "$DAYS_IN_MONTH"); do
    MONTHLY_TABLE="$MONTHLY_TABLE|------"
done
MONTHLY_TABLE="$MONTHLY_TABLE|-------|--------|"

idx=0
for h in "${HABIT_NAMES[@]}"; do
    row="| $h"
    for check in "${DAY_CHECKS[@]}"; do
        habit_check=$(echo "$check" | cut -d'|' -f$((idx + 2)))
        row="$row$habit_check|"
    done
    count=${HABIT_COUNTS[$h]}
    streak=${HABIT_STREAKS[$h]}
    row="$row $count | $streak |"
    MONTHLY_TABLE="$MONTHLY_TABLE
$row"
    idx=$((idx + 1))
done

MONTHLY_TABLE="$MONTHLY_TABLE

*Auto-generated from daily journal entries.*"

# Build weekly table (Mon-Sun)
TODAY=$(date '+%Y-%m-%d')
DOW=$(journal_day_of_week "$TODAY")
DAYS_BACK=$((DOW - 1))
WEEK_START=$(journal_add_days "$TODAY" "-$DAYS_BACK")

WEEKLY_HEADER="| Habit | Mon | Tue | Wed | Thu | Fri | Sat | Sun | Streak |"
WEEKLY_SEP="|-------|-----|-----|-----|-----|-----|-----|-----|--------|"
WEEKLY_ROWS=""

for h in "${HABIT_NAMES[@]}"; do
    row="| $h"
    week_counts=0; week_streak=0; current_run=0
    for i in $(seq 0 6); do
        CHECK_DATE=$(journal_add_days "$WEEK_START" "$i")
        CHECK_FILE=$(journal_entry_path "$REPO_ROOT" "$CHECK_DATE")
        if [ -f "$CHECK_FILE" ]; then
            habits_section=$(sed -n '/^## Habits/,/^## /p' "$CHECK_FILE" | head -n -1 || true)
            if echo "$habits_section" | grep -qiE "^- \[[xX]\] +$h" 2>/dev/null; then
                row="$row| [x]"
                week_counts=$((week_counts + 1))
                current_run=$((current_run + 1))
                [ $current_run -gt $week_streak ] && week_streak=$current_run
            else
                row="$row| [ ]"; current_run=0
            fi
        else
            row="$row| [ ]"; current_run=0
        fi
    done
    row="$row| $week_counts | $week_streak |"
    WEEKLY_ROWS="$WEEKLY_ROWS
$row"
done

WEEKLY_TABLE="$WEEKLY_HEADER
$WEEKLY_SEP$WEEKLY_ROWS"

if [ "$FILL_REVIEW" = true ]; then
    REVIEW_DIR="$REPO_ROOT/reviews"
    if [ -d "$REVIEW_DIR" ]; then
        # ls -1t is portable across GNU/BSD; find -printf is not.
        # shellcheck disable=SC2012
        LATEST_REVIEW=$(ls -1t "$REVIEW_DIR"/*.md 2>/dev/null | head -n1 || true)
        if [ -n "$LATEST_REVIEW" ]; then
            REVIEW_CONTENT=$(cat "$LATEST_REVIEW")
            BEFORE=$(echo "$REVIEW_CONTENT" | sed -n '1,/^## Habit Check-In/p' | sed '$d')
            AFTER=$(echo "$REVIEW_CONTENT" | sed -n '/^\*Run \`\./,$p')
            [ -z "$AFTER" ] && AFTER=$(echo "$REVIEW_CONTENT" | sed -n '/^## Looking Ahead/,$p')
            NEW_CONTENT="$BEFORE
## Habit Check-In

*Auto-filled from daily entries.*

$WEEKLY_TABLE

$AFTER"
            echo "$NEW_CONTENT" > "$LATEST_REVIEW"
            git add "$LATEST_REVIEW"
            cat <<EOOUT
+---------------------------------------------------+
|              HABITS FILLED IN REVIEW               |
+---------------------------------------------------+
|  Review: $(basename "$LATEST_REVIEW")
|                                                   |
|  Weekly habit data injected successfully.         |
+---------------------------------------------------+
EOOUT
        else
            echo "No weekly review found. Outputting habit data:"
            echo "$WEEKLY_TABLE"
        fi
    else
        echo "No reviews directory. Outputting habit data:"
        echo "$WEEKLY_TABLE"
    fi
else
    HABIT_FILE="$MONTH_DIR/habits.md"
    echo "$MONTHLY_TABLE" > "$HABIT_FILE"
    git add "$HABIT_FILE" 2>/dev/null || true
    echo "Habit tracker saved: $HABIT_FILE"
fi

echo ""
echo "Summary for $YEAR-$MONTH:"
for h in "${HABIT_NAMES[@]}"; do
    count=${HABIT_COUNTS[$h]}
    streak=${HABIT_STREAKS[$h]}
    echo "  $h: $count days, best streak: $streak"
done
