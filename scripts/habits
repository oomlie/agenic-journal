#!/bin/bash
set -euo pipefail
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -z "$REPO_ROOT" ]; then echo "Error: Not inside a Git repository."; exit 1; fi

FILL_REVIEW=false
if [ "${1:-}" = "--fill" ] || [ "${1:-}" = "-f" ]; then
    FILL_REVIEW=true; YEAR=$(date '+%Y'); MONTH=$(date '+%m')
elif [ $# -ge 2 ]; then YEAR=$1; MONTH=$2
else YEAR=$(date '+%Y'); MONTH=$(date '+%m'); fi

if ! echo "$MONTH" | grep -qE '^[0-9]{2}$'; then MONTH=$(printf "%02d" "$MONTH"); fi
month_name=$(date -d "$YEAR-$MONTH-01" '+%B' 2>/dev/null)
if [ -z "$month_name" ]; then case "$MONTH" in
    01) month_name="January" ;; 02) month_name="February" ;; 03) month_name="March" ;;
    04) month_name="April" ;; 05) month_name="May" ;; 06) month_name="June" ;;
    07) month_name="July" ;; 08) month_name="August" ;; 09) month_name="September" ;;
    10) month_name="October" ;; 11) month_name="November" ;; 12) month_name="December" ;;
esac; fi

MONTH_DIR="$REPO_ROOT/$YEAR/$MONTH-$(echo "$month_name" | tr '[:upper:]' '[:lower:]')"
if [ ! -d "$MONTH_DIR" ]; then echo "No journal entries found for $month_name $YEAR."; exit 0; fi

HABIT_NAMES=("Exercise" "Read" "Meditate" "Deep Work" "Sleep 8h")
DAYS_IN_MONTH=$(date -d "$YEAR-$MONTH-01 + 1 month - 1 day" '+%d' 2>/dev/null)

declare -A HABIT_COUNTS
declare -A HABIT_STREAKS
declare -A HABIT_CURRENT_STREAK
for h in "${HABIT_NAMES[@]}"; do
    HABIT_COUNTS[$h]=0; HABIT_STREAKS[$h]=0; HABIT_CURRENT_STREAK[$h]=0
done
DAY_CHECKS=()

for day in $(seq -w 1 $DAYS_IN_MONTH); do
    ENTRY_FILE="$MONTH_DIR/$YEAR-$MONTH-$day.md"
    day_checks_row=""
    if [ -f "$ENTRY_FILE" ]; then
        habits_section=$(sed -n '/^## Habits/,/^## /p' "$ENTRY_FILE" | head -n -1 || true)
        for h in "${HABIT_NAMES[@]}"; do
            if echo "$habits_section" | grep -qiE "^- \[[xX]\] +$h" 2>/dev/null; then
                day_checks_row="${day_checks_row}| [x]"
                HABIT_COUNTS[$h]=$((${HABIT_COUNTS[$h]} + 1))
                HABIT_CURRENT_STREAK[$h]=$((${HABIT_CURRENT_STREAK[$h]} + 1))
                if [ ${HABIT_CURRENT_STREAK[$h]} -gt ${HABIT_STREAKS[$h]} ]; then
                    HABIT_STREAKS[$h]=${HABIT_CURRENT_STREAK[$h]}
                fi
            else
                day_checks_row="${day_checks_row}| [ ]"
                HABIT_CURRENT_STREAK[$h]=0
            fi
        done
    else
        for h in "${HABIT_NAMES[@]}"; do
            day_checks_row="${day_checks_row}| [ ]"
            HABIT_CURRENT_STREAK[$h]=0
        done
    fi
    DAY_CHECKS+=("$day_checks_row")
done

MONTHLY_TABLE="# Habit Tracker -- $month_name $YEAR

| Habit"
for day in $(seq -w 1 $DAYS_IN_MONTH); do
    day_num=$(echo "$day" | sed 's/^0//')
    MONTHLY_TABLE="$MONTHLY_TABLE | $day_num"
done
MONTHLY_TABLE="$MONTHLY_TABLE | Total | Streak |"

MONTHLY_TABLE="$MONTHLY_TABLE
|-------"
for day in $(seq 1 $DAYS_IN_MONTH); do
    MONTHLY_TABLE="$MONTHLY_TABLE|------"
done
MONTHLY_TABLE="$MONTHLY_TABLE|-------|--------|"

idx=0
for h in "${HABIT_NAMES[@]}"; do
    row="| $h"
    for check in "${DAY_CHECKS[@]}"; do
        habit_check=$(echo "$check" | cut -d'|' -f$((idx + 2)))
        row="$row$habit_check|"
    done
    count=${HABIT_COUNTS[$h]}
    streak=${HABIT_STREAKS[$h]}
    row="$row $count | $streak |"
    MONTHLY_TABLE="$MONTHLY_TABLE
$row"
    idx=$((idx + 1))
done

MONTHLY_TABLE="$MONTHLY_TABLE

*Auto-generated from daily journal entries.*"

TODAY=$(date '+%Y-%m-%d')
DOW=$(date -d "$TODAY" '+%u' 2>/dev/null)
DAYS_BACK=$((DOW - 1))
WEEK_START=$(date -d "$TODAY - $DAYS_BACK days" '+%Y-%m-%d' 2>/dev/null)

WEEKLY_HEADER="| Habit | Mon | Tue | Wed | Thu | Fri | Sat | Sun | Streak |"
WEEKLY_SEP="|-------|-----|-----|-----|-----|-----|-----|-----|--------|"
WEEKLY_ROWS=""

for h in "${HABIT_NAMES[@]}"; do
    row="| $h"
    week_counts=0; week_streak=0; current_run=0
    for i in $(seq 0 6); do
        CHECK_DATE=$(date -d "$WEEK_START + $i days" '+%Y-%m-%d' 2>/dev/null)
        cy=$(echo "$CHECK_DATE" | cut -d'-' -f1); cm=$(echo "$CHECK_DATE" | cut -d'-' -f2)
        cmonth=$(date -d "$CHECK_DATE" '+%B' 2>/dev/null)
        if [ -z "$cmonth" ]; then case "$cm" in
            01) cmonth="January" ;; 02) cmonth="February" ;; 03) cmonth="March" ;;
            04) cmonth="April" ;; 05) cmonth="May" ;; 06) cmonth="June" ;;
            07) cmonth="July" ;; 08) cmonth="August" ;; 09) cmonth="September" ;;
            10) cmonth="October" ;; 11) cmonth="November" ;; 12) cmonth="December" ;;
        esac; fi
        CHECK_FILE="$REPO_ROOT/$cy/$cm-$(echo "$cmonth" | tr '[:upper:]' '[:lower:]')/$CHECK_DATE.md"
        if [ -f "$CHECK_FILE" ]; then
            habits_section=$(sed -n '/^## Habits/,/^## /p' "$CHECK_FILE" | head -n -1 || true)
            if echo "$habits_section" | grep -qiE "^- \[[xX]\] +$h" 2>/dev/null; then
                row="$row| [x]"
                week_counts=$((week_counts + 1))
                current_run=$((current_run + 1))
                [ $current_run -gt $week_streak ] && week_streak=$current_run
            else
                row="$row| [ ]"; current_run=0
            fi
        else
            row="$row| [ ]"; current_run=0
        fi
    done
    row="$row| $week_counts | $week_streak |"
    WEEKLY_ROWS="$WEEKLY_ROWS
$row"
done

WEEKLY_TABLE="$WEEKLY_HEADER
$WEEKLY_SEP$WEEKLY_ROWS"

if [ "$FILL_REVIEW" = true ]; then
    REVIEW_DIR="$REPO_ROOT/reviews"
    if [ -d "$REVIEW_DIR" ]; then
        LATEST_REVIEW=$(ls -1t "$REVIEW_DIR"/*.md 2>/dev/null | head -n1 || true)
        if [ -n "$LATEST_REVIEW" ]; then
            REVIEW_CONTENT=$(cat "$LATEST_REVIEW")
            BEFORE=$(echo "$REVIEW_CONTENT" | sed -n '1,/^## Habit Check-In/p' | sed '$d')
            AFTER=$(echo "$REVIEW_CONTENT" | sed -n '/^\*Run \`\./,$p')
            if [ -z "$AFTER" ]; then AFTER=$(echo "$REVIEW_CONTENT" | sed -n '/^## Looking Ahead/,$p'); fi
            NEW_CONTENT="$BEFORE
## Habit Check-In

*Auto-filled from daily entries.*

$WEEKLY_TABLE

$AFTER"
            echo "$NEW_CONTENT" > "$LATEST_REVIEW"
            git add "$LATEST_REVIEW"
            cat <<EOOUT
+---------------------------------------------------+
|              HABITS FILLED IN REVIEW               |
+---------------------------------------------------+
|  Review: $(basename "$LATEST_REVIEW")
|                                                   |
|  Weekly habit data injected successfully.         |
+---------------------------------------------------+
EOOUT
        else
            echo "No weekly review found. Outputting habit data:"
            echo "$WEEKLY_TABLE"
        fi
    else
        echo "No reviews directory. Outputting habit data:"
        echo "$WEEKLY_TABLE"
    fi
else
    HABIT_FILE="$REPO_ROOT/$YEAR/$MONTH-$(echo "$month_name" | tr '[:upper:]' '[:lower:]')/habits.md"
    echo "$MONTHLY_TABLE" > "$HABIT_FILE"
    git add "$HABIT_FILE" 2>/dev/null || true
    echo "Habit tracker saved: $HABIT_FILE"
fi

echo ""
echo "Summary for $month_name $YEAR:"
for h in "${HABIT_NAMES[@]}"; do
    count=${HABIT_COUNTS[$h]}
    streak=${HABIT_STREAKS[$h]}
    echo "  $h: $count days, best streak: $streak"
done
