#!/bin/bash
#
# week-review
# Generates a weekly review from the past 7 days of journal entries.
# Best run on Sunday afternoons.
#
# Usage:
#   ./scripts/week-review              # Review last 7 days
#   ./scripts/week-review 2026-07-06   # Review week starting from a specific Monday
#

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)

if [ -z "$REPO_ROOT" ]; then
    echo "Error: Not inside a Git repository."
    exit 1
fi

# --- Determine week range ---

if [ -n "${1:-}" ]; then
    WEEK_START="$1"
    if ! echo "$WEEK_START" | grep -qE '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'; then
        echo "Error: Date must be YYYY-MM-DD format."
        exit 1
    fi
else
    # Default: find the most recent Monday
    TODAY=$(date '+%Y-%m-%d')
    DOW=$(date -d "$TODAY" '+%u' 2>/dev/null || date -j -f '%Y-%m-%d' "$TODAY" '+%u' 2>/dev/null)
    DAYS_BACK=$((DOW - 1))
    WEEK_START=$(date -d "$TODAY - $DAYS_BACK days" '+%Y-%m-%d' 2>/dev/null || date -v-${DAYS_BACK}d -j -f '%Y-%m-%d' "$TODAY" '+%Y-%m-%d' 2>/dev/null)
fi

# Calculate week end (Sunday)
WEEK_END=$(date -d "$WEEK_START + 6 days" '+%Y-%m-%d' 2>/dev/null || date -v+6d -j -f '%Y-%m-%d' "$WEEK_START" '+%Y-%m-%d' 2>/dev/null)
WEEK_NUM=$(date -d "$WEEK_START" '+%V' 2>/dev/null || date -j -f '%Y-%m-%d' "$WEEK_START" '+%V' 2>/dev/null)
YEAR=$(echo "$WEEK_START" | cut -d'-' -f1)

# --- Collect entry files ---

ENTRY_FILES=()
CURRENT="$WEEK_START"
while [ "$CURRENT" != "$(date -d "$WEEK_END + 1 day" '+%Y-%m-%d' 2>/dev/null || date -v+1d -j -f '%Y-%m-%d' "$WEEK_END" '+%Y-%m-%d' 2>/dev/null)" ]; do
    y=$(echo "$CURRENT" | cut -d'-' -f1)
    m=$(echo "$CURRENT" | cut -d'-' -f2)
    month_name=$(date -d "$CURRENT" '+%B' 2>/dev/null || date -j -f '%Y-%m-%d' "$CURRENT" '+%B' 2>/dev/null)
    if [ -z "$month_name" ]; then
        case "$m" in
            01) month_name="January" ;; 02) month_name="February" ;; 03) month_name="March" ;;
            04) month_name="April" ;; 05) month_name="May" ;; 06) month_name="June" ;;
            07) month_name="July" ;; 08) month_name="August" ;; 09) month_name="September" ;;
            10) month_name="October" ;; 11) month_name="November" ;; 12) month_name="December" ;;
        esac
    fi
    f="$REPO_ROOT/$y/$m-$(echo "$month_name" | tr '[:upper:]' '[:lower:]')/$CURRENT.md"
    if [ -f "$f" ]; then
        ENTRY_FILES+=("$f")
    fi
    CURRENT=$(date -d "$CURRENT + 1 day" '+%Y-%m-%d' 2>/dev/null || date -v+1d -j -f '%Y-%m-%d' "$CURRENT" '+%Y-%m-%d' 2>/dev/null)
done

if [ ${#ENTRY_FILES[@]} -eq 0 ]; then
    echo "No journal entries found for week of $WEEK_START to $WEEK_END."
    exit 0
fi

echo "Found ${#ENTRY_FILES[@]} entry(s) for week $WEEK_NUM ($WEEK_START → $WEEK_END)"

# --- Parse data ---

TOTAL_TASKS=0
COMPLETED_TASKS=0
ROLLED_TASKS=0
ENERGY_SUM=0
ENERGY_COUNT=0
ALL_TAGS=""
ALL_WINS=""
ALL_STRUGGLES=""
ALL_LOGS=""
DAY_NAMES=()

for f in "${ENTRY_FILES[@]}"; do
    content=$(cat "$f")
    day_date=$(basename "$f" .md)
    day_name=$(date -d "$day_date" '+%A' 2>/dev/null || date -j -f '%Y-%m-%d' "$day_date" '+%A' 2>/dev/null || echo "Day")
    DAY_NAMES+=("$day_name")

    # Tasks
    tasks=$(echo "$content" | grep -cE '^\s*- \[([ xX>])\]' || true)
    completed=$(echo "$content" | grep -cE '^\s*- \[[xX]\]' || true)
    rolled=$(echo "$content" | grep -cE '^\s*- \[>\]' || true)
    TOTAL_TASKS=$((TOTAL_TASKS + tasks))
    COMPLETED_TASKS=$((COMPLETED_TASKS + completed))
    ROLLED_TASKS=$((ROLLED_TASKS + rolled))

    # Energy
    energy_line=$(echo "$content" | grep -iE '^\*\*Energy \(1-10\):\*\*' || true)
    if [ -n "$energy_line" ]; then
        energy_val=$(echo "$energy_line" | grep -oE '[0-9]+' | head -n1 || true)
        if [ -n "$energy_val" ] && [ "$energy_val" -ge 1 ] && [ "$energy_val" -le 10 ]; then
            ENERGY_SUM=$((ENERGY_SUM + energy_val))
            ENERGY_COUNT=$((ENERGY_COUNT + 1))
        fi
    fi

    # Tags
    tags=$(echo "$content" | grep -oE '#[a-zA-Z0-9_-]+' || true)
    if [ -n "$tags" ]; then
        ALL_TAGS="$ALL_TAGS
$tags"
    fi

    # Wins
    wins=$(echo "$content" | sed -n '/^### Wins Today/,/^### /p' | grep -E '^[0-9]+\.' || true)
    if [ -n "$wins" ]; then
        ALL_WINS="$ALL_WINS
**$day_name**: $wins"
    fi

    # Struggles
    struggles=$(echo "$content" | sed -n '/^### Struggles \/ Notes/,/^### /p' | grep -v '^### ' | grep -v '^$' || true)
    if [ -n "$struggles" ]; then
        ALL_STRUGGLES="$ALL_STRUGGLES
**$day_name**: $struggles"
    fi

    # Logs
    logs=$(echo "$content" | grep -E '^- [0-9]{2}:[0-9]{2} —' || true)
    if [ -n "$logs" ]; then
        ALL_LOGS="$ALL_LOGS
### $day_name
$logs"
    fi
done

# --- Calculate metrics ---

if [ $TOTAL_TASKS -gt 0 ]; then
    TASK_RATE=$((COMPLETED_TASKS * 100 / TOTAL_TASKS))
else
    TASK_RATE=0
fi

if [ $ENERGY_COUNT -gt 0 ]; then
    ENERGY_AVG=$((ENERGY_SUM / ENERGY_COUNT))
else
    ENERGY_AVG="—"
fi

# Top tags
TOP_TAGS=$(echo "$ALL_TAGS" | tr ' ' '\n' | sort | uniq -c | sort -rn | head -n 5 | sed 's/^ *[0-9]* /- /' || true)

# --- Build review ---

mkdir -p "$REPO_ROOT/reviews"
REVIEW_FILE="$REPO_ROOT/reviews/$YEAR-W$WEEK_NUM.md"

cat > "$REVIEW_FILE" <<EOF
# Week $WEEK_NUM Review — $WEEK_START to $WEEK_END

## Snapshot

| Metric | Value |
|--------|-------|
| Days Journaled | ${#ENTRY_FILES[@]} / 7 |
| Tasks Completed | $COMPLETED_TASKS / $TOTAL_TASKS ($TASK_RATE%) |
| Tasks Rolled Over | $ROLLED_TASKS |
| Avg Energy | $ENERGY_AVG / 10 |

### Top Tags
$TOP_TAGS

---

## Wins This Week
$ALL_WINS

---

## Struggles / Patterns
$ALL_STRUGGLES

---

## Daily Logs
$ALL_LOGS

---

## Habit Check-In

<!-- Fill in your habit streaks below. Checked habits are tallied from daily entries. -->

| Habit | Mon | Tue | Wed | Thu | Fri | Sat | Sun | Streak |
|-------|-----|-----|-----|-----|-----|-----|-----|--------|
| Exercise | | | | | | | | |
| Read | | | | | | | | |
| Meditate | | | | | | | | |
| Deep Work | | | | | | | | |
| Sleep 8h | | | | | | | | |

*Run \`./scripts/habits\` to auto-fill from daily entries.*

---

## Looking Ahead

- [ ] Priority for next week:
- [ ] Something to try differently:
- [ ] One thing to look forward to:

---

#weekly-review
EOF

git add "$REVIEW_FILE"

echo ""
echo "Week $WEEK_NUM review created: $REVIEW_FILE"
echo ""
echo "Summary:"
echo "  Days journaled: ${#ENTRY_FILES[@]}/7"
echo "  Tasks: $COMPLETED_TASKS/$TOTAL_TASKS completed ($TASK_RATE%)"
echo "  Rolled over: $ROLLED_TASKS"
echo "  Avg energy: $ENERGY_AVG/10"
if [ -n "$TOP_TAGS" ]; then
    echo "  Top tags:"
    echo "$TOP_TAGS" | sed 's/^/    /'
fi
