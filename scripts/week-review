#!/bin/bash
set -euo pipefail
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -z "$REPO_ROOT" ]; then echo "Error: Not inside a Git repository."; exit 1; fi
if [ -n "${1:-}" ]; then WEEK_START="$1"
else
    TODAY=$(date '+%Y-%m-%d'); DOW=$(date -d "$TODAY" '+%u' 2>/dev/null)
    DAYS_BACK=$((DOW - 1))
    WEEK_START=$(date -d "$TODAY - $DAYS_BACK days" '+%Y-%m-%d' 2>/dev/null)
fi
WEEK_END=$(date -d "$WEEK_START + 6 days" '+%Y-%m-%d' 2>/dev/null)
WEEK_NUM=$(date -d "$WEEK_START" '+%V' 2>/dev/null)
YEAR=$(echo "$WEEK_START" | cut -d'-' -f1)

ENTRY_FILES=()
CURRENT="$WEEK_START"
while [ "$CURRENT" != "$(date -d "$WEEK_END + 1 day" '+%Y-%m-%d' 2>/dev/null)" ]; do
    y=$(echo "$CURRENT" | cut -d'-' -f1); m=$(echo "$CURRENT" | cut -d'-' -f2)
    month_name=$(date -d "$CURRENT" '+%B' 2>/dev/null)
    if [ -z "$month_name" ]; then case "$m" in
        01) month_name="January" ;; 02) month_name="February" ;; 03) month_name="March" ;;
        04) month_name="April" ;; 05) month_name="May" ;; 06) month_name="June" ;;
        07) month_name="July" ;; 08) month_name="August" ;; 09) month_name="September" ;;
        10) month_name="October" ;; 11) month_name="November" ;; 12) month_name="December" ;;
    esac; fi
    f="$REPO_ROOT/$y/$m-$(echo "$month_name" | tr '[:upper:]' '[:lower:]')/$CURRENT.md"
    [ -f "$f" ] && ENTRY_FILES+=("$f")
    CURRENT=$(date -d "$CURRENT + 1 day" '+%Y-%m-%d' 2>/dev/null)
done

if [ ${#ENTRY_FILES[@]} -eq 0 ]; then echo "No journal entries found for week of $WEEK_START to $WEEK_END."; exit 0; fi
echo "Found ${#ENTRY_FILES[@]} entry(s) for week $WEEK_NUM ($WEEK_START -> $WEEK_END)"

TOTAL_TASKS=0; COMPLETED_TASKS=0; ROLLED_TASKS=0; ENERGY_SUM=0; ENERGY_COUNT=0
ALL_TAGS=""; ALL_WINS=""; ALL_STRUGGLES=""; ALL_LOGS=""

for f in "${ENTRY_FILES[@]}"; do
    content=$(cat "$f")
    day_date=$(basename "$f" .md)
    day_name=$(head -1 "$f" | sed 's/.*-- //' 2>/dev/null || echo "$day_date")
    tasks=$(echo "$content" | grep -cE '^\s*- \[([ xX>])\]' || true)
    completed=$(echo "$content" | grep -cE '^\s*- \[[xX]\]' || true)
    rolled=$(echo "$content" | grep -cE '^\s*- \[>\]' || true)
    TOTAL_TASKS=$((TOTAL_TASKS + tasks))
    COMPLETED_TASKS=$((COMPLETED_TASKS + completed))
    ROLLED_TASKS=$((ROLLED_TASKS + rolled))
    energy_line=$(echo "$content" | grep -iE '^\*\*Energy \(1-10\):\*\*' || true)
    if [ -n "$energy_line" ]; then
        energy_val=$(echo "$energy_line" | sed 's/^\*\*Energy (1-10):\*\*//' | grep -oE '[0-9]+' | head -n1 || true)
        if [ -n "$energy_val" ] && [ "$energy_val" -ge 1 ] && [ "$energy_val" -le 10 ] 2>/dev/null; then
            ENERGY_SUM=$((ENERGY_SUM + energy_val)); ENERGY_COUNT=$((ENERGY_COUNT + 1))
        fi
    fi
    tags=$(echo "$content" | grep -oE '#[a-zA-Z0-9_-]+' || true)
    [ -n "$tags" ] && ALL_TAGS="$ALL_TAGS
$tags"
    wins=$(echo "$content" | sed -n '/^### Wins Today/,/^### /p' | tail -n +2 | grep -E '^[0-9]+\.' || true)
    [ -n "$wins" ] && ALL_WINS="$ALL_WINS
**$day_name**: $wins"
    struggles=$(echo "$content" | sed -n '/^### Struggles \/ Notes/,/^### /p' | tail -n +2 | grep -v '^$' | grep -v '^### ' || true)
    [ -n "$struggles" ] && ALL_STRUGGLES="$ALL_STRUGGLES
**$day_name**: $struggles"
    logs=$(echo "$content" | grep -E '^- [0-9]{2}:[0-9]{2} --' || true)
    [ -n "$logs" ] && ALL_LOGS="$ALL_LOGS
### $day_name
$logs"
done

[ $TOTAL_TASKS -gt 0 ] && TASK_RATE=$((COMPLETED_TASKS * 100 / TOTAL_TASKS)) || TASK_RATE=0
[ $ENERGY_COUNT -gt 0 ] && ENERGY_AVG=$((ENERGY_SUM / ENERGY_COUNT)) || ENERGY_AVG="-"
TOP_TAGS=$(echo "$ALL_TAGS" | tr ' ' '\n' | sort | uniq -c | sort -rn | head -n 5 | sed 's/^ *[0-9]* /- /' || true)

HEADER=$(cat <<'EOF'
    _      _      _
 __(.)< __(.)> __(.)=
 \_)    \_)    \_)
EOF
)

mkdir -p "$REPO_ROOT/reviews"
REVIEW_FILE="$REPO_ROOT/reviews/$YEAR-W$WEEK_NUM.md"

cat > "$REVIEW_FILE" <<EOF
# Week $WEEK_NUM Review -- $WEEK_START to $WEEK_END

$HEADER

## Snapshot

| Metric | Value |
|--------|-------|
| Days Journaled | ${#ENTRY_FILES[@]} / 7 |
| Tasks Completed | $COMPLETED_TASKS / $TOTAL_TASKS ($TASK_RATE%) |
| Tasks Rolled Over | $ROLLED_TASKS |
| Avg Energy | $ENERGY_AVG / 10 |

### Top Tags
$TOP_TAGS

---

## Wins This Week
$ALL_WINS

---

## Struggles / Patterns
$ALL_STRUGGLES

---

## Daily Logs
$ALL_LOGS

---

## Habit Check-In

*Run \`./scripts/habits --fill\` to auto-fill from daily entries.*

| Habit | Mon | Tue | Wed | Thu | Fri | Sat | Sun | Streak |
|-------|-----|-----|-----|-----|-----|-----|-----|--------|
| Exercise | | | | | | | | |
| Read | | | | | | | | |
| Meditate | | | | | | | | |
| Deep Work | | | | | | | | |
| Sleep 8h | | | | | | | | |

---

## Looking Ahead

- [ ] Priority for next week:
- [ ] Something to try differently:
- [ ] One thing to look forward to:

---

#weekly-review
EOF

git add "$REVIEW_FILE"
echo ""; echo "Week $WEEK_NUM review created: $REVIEW_FILE"
echo ""; echo "Summary:"
echo "  Days journaled: ${#ENTRY_FILES[@]}/7"
echo "  Tasks: $COMPLETED_TASKS/$TOTAL_TASKS completed ($TASK_RATE%)"
echo "  Rolled over: $ROLLED_TASKS"
echo "  Avg energy: $ENERGY_AVG/10"
[ -n "$TOP_TAGS" ] && { echo "  Top tags:"; echo "$TOP_TAGS" | sed 's/^/    /'; }
