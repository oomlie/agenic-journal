#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

REPO_ROOT=$(journal_require_repo_root)

if [ -n "${1:-}" ]; then
    ENTRY_DATE="$1"
    journal_validate_date "$ENTRY_DATE"
else
    ENTRY_DATE=$(date '+%Y-%m-%d')
fi

YEAR=$(echo "$ENTRY_DATE" | cut -d'-' -f1)
MONTH_NUM=$(echo "$ENTRY_DATE" | cut -d'-' -f2)
MONTH_NAME=$(journal_month_name_from_date "$ENTRY_DATE")
MONTH_DIR="$REPO_ROOT/$YEAR/$MONTH_NUM-$(echo "$MONTH_NAME" | tr '[:upper:]' '[:lower:]')"
ENTRY_FILE="$MONTH_DIR/$ENTRY_DATE.md"

if [ -f "$ENTRY_FILE" ]; then
    echo "Entry already exists: $ENTRY_FILE"
    exit 0
fi

mkdir -p "$MONTH_DIR"
DAY_NAME=$(journal_day_name "$ENTRY_DATE")

cat > "$ENTRY_FILE" <<EOF
# $ENTRY_DATE -- $DAY_NAME

## Morning

**Energy (1-10):**
**Mood:**
**Intention for today:**

### Top 3 Priorities
1. [ ]
2. [ ]
3. [ ]

---

## Time Blocks

### Block 1 -- :00 - :00
Focus:
- [ ] Task
- Notes:

### Block 2 -- :00 - :00
Focus:
- [ ] Task
- Notes:

### Block 3 -- :00 - :00
Focus:
- [ ] Task
- Notes:

---

## Log

- $(date '+%H:%M') -- Entry created
- :: --
- :: --

---

## Habits

- [ ] Exercise
- [ ] Read
- [ ] Meditate
- [ ] Deep Work
- [ ] Sleep 8h

---

## Evening

### Wins Today
1.
2.
3.

### Struggles / Notes

### Gratitude

### Tomorrow's Setup
- [ ]
- [ ]

---

#journal #$MONTH_NAME
EOF

cat <<EOOUT
+---------------------------------------------------+
|                  NEW DAY CREATED                   |
+---------------------------------------------------+
|  $ENTRY_DATE -- $DAY_NAME
|  $ENTRY_FILE
+---------------------------------------------------+
EOOUT
