#!/bin/bash
#
# journal - Unified CLI for agenic-journal
#
# Usage: ./scripts/journal <command> [args...]
#        ./scripts/journal help          Show all commands
#
# Commands:
#   new [DATE]           Scaffold a new daily entry
#   log "NOTE" [OPTS]    Append a timestamped note
#   rollover [DATE]      Carry unchecked tasks forward
#   review [DATE]        Generate weekly review
#   habits [OPTS]        Tally habit streaks
#   remember [OPTS]      Resurface a random past entry
#   streak [OPTS]        Show journaling streaks
#   setup                Enable Git hooks (one-time)
#

set -euo pipefail

# ---------------------------------------------------------------------------
# Shared helpers
# ---------------------------------------------------------------------------

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -z "$REPO_ROOT" ]; then
    echo "Error: Not inside a Git repository."
    exit 1
fi

_J_month_name() {
    local num="$1"
    case "$num" in
        01) echo "January" ;; 02) echo "February" ;; 03) echo "March" ;;
        04) echo "April" ;; 05) echo "May" ;; 06) echo "June" ;;
        07) echo "July" ;; 08) echo "August" ;; 09) echo "September" ;;
        10) echo "October" ;; 11) echo "November" ;; 12) echo "December" ;;
    esac
}

_J_resolve() {
    local d="$1"
    local y=$(echo "$d" | cut -d'-' -f1)
    local m=$(echo "$d" | cut -d'-' -f2)
    local month_name=$(date -d "$d" '+%B' 2>/dev/null)
    [ -z "$month_name" ] && month_name=$(_J_month_name "$m")
    echo "$REPO_ROOT/$y/$m-$(echo "$month_name" | tr '[:upper:]' '[:lower:]')/$d.md"
}

# ---------------------------------------------------------------------------
# new - Scaffold a new daily entry
# ---------------------------------------------------------------------------
cmd_new() {
    if [ -n "${1:-}" ]; then ENTRY_DATE="$1"
    else ENTRY_DATE=$(date '+%Y-%m-%d'); fi

    YEAR=$(echo "$ENTRY_DATE" | cut -d'-' -f1)
    MONTH_NUM=$(echo "$ENTRY_DATE" | cut -d'-' -f2)
    MONTH_NAME=$(date -d "$ENTRY_DATE" '+%B' 2>/dev/null)
    [ -z "$MONTH_NAME" ] && MONTH_NAME=$(_J_month_name "$MONTH_NUM")

    MONTH_DIR="$REPO_ROOT/$YEAR/$MONTH_NUM-$(echo "$MONTH_NAME" | tr '[:upper:]' '[:lower:]')"
    ENTRY_FILE="$MONTH_DIR/$ENTRY_DATE.md"

    if [ -f "$ENTRY_FILE" ]; then
        echo "Entry already exists: $ENTRY_FILE"
        exit 0
    fi

    mkdir -p "$MONTH_DIR"
    DAY_NAME=$(date -d "$ENTRY_DATE" '+%A' 2>/dev/null || echo "Day")

    cat > "$ENTRY_FILE" <<EOF
# $ENTRY_DATE -- $DAY_NAME

## Morning

**Energy (1-10):**
**Mood:**
**Intention for today:**

### Top 3 Priorities
1. [ ]
2. [ ]
3. [ ]

---

## Time Blocks

### Block 1 -- :00 - :00
Focus:
- [ ] Task
- Notes:

### Block 2 -- :00 - :00
Focus:
- [ ] Task
- Notes:

### Block 3 -- :00 - :00
Focus:
- [ ] Task
- Notes:

---

## Log

- $(date '+%H:%M') -- Entry created
- :: --
- :: --

---

## Habits

- [ ] Exercise
- [ ] Read
- [ ] Meditate
- [ ] Deep Work
- [ ] Sleep 8h

---

## Evening

### Wins Today
1.
2.
3.

### Struggles / Notes

### Gratitude

### Tomorrow's Setup
- [ ]
- [ ]

---

#journal #$MONTH_NAME
EOF

    cat <<EOOUT
+---------------------------------------------------+
|                  NEW DAY CREATED                   |
+---------------------------------------------------+
|  $ENTRY_DATE -- $DAY_NAME
|  $ENTRY_FILE
+---------------------------------------------------+
EOOUT
}

# ---------------------------------------------------------------------------
# log - Append a timestamped note
# ---------------------------------------------------------------------------
cmd_log() {
    MESSAGE=""; TARGET_DATE=""; NO_COMMIT=false; TAG=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -d|--date) TARGET_DATE="$2"; shift 2;;
            -n|--no-commit) NO_COMMIT=true; shift;;
            -t|--tag) TAG="$2"; shift 2;;
            -*) echo "Unknown flag: $1"; exit 1;;
            *)
                if [ -z "$MESSAGE" ]; then MESSAGE="$1"
                else MESSAGE="$MESSAGE $1"; fi
                shift;;
        esac
    done

    if [ -z "$MESSAGE" ]; then
        echo "Usage: journal log \"your note here\" [-d YYYY-MM-DD] [-t tag] [-n]"
        exit 1
    fi

    if [ -n "$TARGET_DATE" ]; then ENTRY_DATE="$TARGET_DATE"
    else ENTRY_DATE=$(date '+%Y-%m-%d'); fi

    YEAR=$(echo "$ENTRY_DATE" | cut -d'-' -f1)
    MONTH_NUM=$(echo "$ENTRY_DATE" | cut -d'-' -f2)
    MONTH_NAME=$(date -d "$ENTRY_DATE" '+%B' 2>/dev/null)
    [ -z "$MONTH_NAME" ] && MONTH_NAME=$(_J_month_name "$MONTH_NUM")

    MONTH_DIR="$REPO_ROOT/$YEAR/$MONTH_NUM-$(echo "$MONTH_NAME" | tr '[:upper:]' '[:lower:]')"
    ENTRY_FILE="$MONTH_DIR/$ENTRY_DATE.md"

    if [ ! -f "$ENTRY_FILE" ]; then
        cmd_new "$ENTRY_DATE" >/dev/null
    fi

    TIMESTAMP=$(date '+%H:%M')
    LOG_LINE="- $TIMESTAMP -- $MESSAGE"
    [ -n "$TAG" ] && LOG_LINE="$LOG_LINE #$TAG"

    if grep -qE '^- [0-9]{2}:[0-9]{2} --' "$ENTRY_FILE"; then
        LAST_LOG_LINE=$(grep -nE '^- [0-9]{2}:[0-9]{2} --' "$ENTRY_FILE" | tail -n1 | cut -d':' -f1)
        sed -i "${LAST_LOG_LINE}a\\ $LOG_LINE" "$ENTRY_FILE"
    else
        LOG_HEADER_LINE=$(grep -n '^## Log$' "$ENTRY_FILE" | head -n1 | cut -d':' -f1)
        if [ -n "$LOG_HEADER_LINE" ]; then
            sed -i "${LOG_HEADER_LINE}a\\ \\$LOG_LINE" "$ENTRY_FILE"
        else
            echo "" >> "$ENTRY_FILE"
            echo "$LOG_LINE" >> "$ENTRY_FILE"
        fi
    fi

    git add "$ENTRY_FILE"

    if [ "$NO_COMMIT" = true ]; then
        cat <<EOOUT
+---------------------------------------------------+
|                     LOGGED                         |
+---------------------------------------------------+
|  $LOG_LINE
|                                                   |
|  (staged, not committed)                          |
+---------------------------------------------------+
EOOUT
    else
        SHORT_MSG=$(echo "$MESSAGE" | cut -c1-50)
        git commit -m "[$ENTRY_DATE $TIMESTAMP] $SHORT_MSG" --quiet
        cat <<EOOUT
+---------------------------------------------------+
|                     LOGGED                         |
+---------------------------------------------------+
|  $LOG_LINE
+---------------------------------------------------+
EOOUT
    fi
}

# ---------------------------------------------------------------------------
# rollover - Carry unchecked tasks forward
# ---------------------------------------------------------------------------
cmd_rollover() {
    if [ -n "${1:-}" ]; then
        SOURCE_DATE="$1"
        TARGET_DATE=$(date -d "$SOURCE_DATE + 1 day" '+%Y-%m-%d' 2>/dev/null)
    else
        TARGET_DATE=$(date '+%Y-%m-%d')
        SOURCE_DATE=$(date -d "$TARGET_DATE - 1 day" '+%Y-%m-%d' 2>/dev/null)
    fi

    SOURCE_FILE=$(_J_resolve "$SOURCE_DATE")
    TARGET_FILE=$(_J_resolve "$TARGET_DATE")

    if [ ! -f "$SOURCE_FILE" ]; then
        echo "No entry found for $SOURCE_DATE. Nothing to roll over."
        exit 0
    fi

    if [ ! -f "$TARGET_FILE" ]; then
        cmd_new "$TARGET_DATE" >/dev/null
    fi

    UNCHECKED=$(sed -n '/^### Top 3 Priorities/,/^---$/p' "$SOURCE_FILE" | grep -E '^[0-9]+\. \[ \]' || true)

    if [ -z "$UNCHECKED" ]; then
        echo "No unchecked tasks in $SOURCE_DATE. You're all caught up!"
        exit 0
    fi

    ROLLOVER_BLOCK="### Rolled Over from $SOURCE_DATE"
    while IFS= read -r line; do
        task_text=$(echo "$line" | sed -E 's/^[0-9]+\. \[ \] //')
        ROLLOVER_BLOCK="$ROLLOVER_BLOCK
- [ ] $task_text"
    done <<< "$UNCHECKED"

    python3 << PYEOF
with open("$TARGET_FILE", 'r') as f:
    lines = f.readlines()

insert_after = -1
for i, line in enumerate(lines):
    if line.strip() == '### Top 3 Priorities':
        insert_after = i
        break

if insert_after >= 0:
    insert_lines = ['\n'] + [l + '\n' for l in """$ROLLOVER_BLOCK""".split('\n')] + ['\n']
    new_lines = lines[:insert_after+1] + insert_lines + lines[insert_after+1:]
    with open("$TARGET_FILE", 'w') as f:
        f.writelines(new_lines)
else:
    with open("$TARGET_FILE", 'a') as f:
        f.write('\n' + """$ROLLOVER_BLOCK""" + '\n')
PYEOF

    sed -i 's/^\([0-9]*\. \)\[ \]/\1[>]/g' "$SOURCE_FILE"
    git add "$SOURCE_FILE" "$TARGET_FILE"

    NUM_TASKS=$(echo "$UNCHECKED" | wc -l | tr -d ' ')
    cat <<EOOUT
+---------------------------------------------------+
|              TASKS ROLLED OVER                     |
+---------------------------------------------------+
|  $NUM_TASKS task(s) from $SOURCE_DATE -> $TARGET_DATE  |
|                                                   |
|  Run 'git commit' when ready.                     |
|  Hooks will auto-message it.                      |
+---------------------------------------------------+
EOOUT
}

# ---------------------------------------------------------------------------
# review - Generate weekly review
# ---------------------------------------------------------------------------
cmd_review() {
    if [ -n "${1:-}" ]; then WEEK_START="$1"
    else
        TODAY=$(date '+%Y-%m-%d')
        DOW=$(date -d "$TODAY" '+%u' 2>/dev/null)
        DAYS_BACK=$((DOW - 1))
        WEEK_START=$(date -d "$TODAY - $DAYS_BACK days" '+%Y-%m-%d' 2>/dev/null)
    fi

    WEEK_END=$(date -d "$WEEK_START + 6 days" '+%Y-%m-%d' 2>/dev/null)
    WEEK_NUM=$(date -d "$WEEK_START" '+%V' 2>/dev/null)
    YEAR=$(echo "$WEEK_START" | cut -d'-' -f1)

    ENTRY_FILES=()
    CURRENT="$WEEK_START"
    while [ "$CURRENT" != "$(date -d "$WEEK_END + 1 day" '+%Y-%m-%d' 2>/dev/null)" ]; do
        y=$(echo "$CURRENT" | cut -d'-' -f1)
        m=$(echo "$CURRENT" | cut -d'-' -f2)
        month_name=$(date -d "$CURRENT" '+%B' 2>/dev/null)
        [ -z "$month_name" ] && month_name=$(_J_month_name "$m")
        f="$REPO_ROOT/$y/$m-$(echo "$month_name" | tr '[:upper:]' '[:lower:]')/$CURRENT.md"
        [ -f "$f" ] && ENTRY_FILES+=("$f")
        CURRENT=$(date -d "$CURRENT + 1 day" '+%Y-%m-%d' 2>/dev/null)
    done

    if [ ${#ENTRY_FILES[@]} -eq 0 ]; then
        echo "No journal entries found for week of $WEEK_START to $WEEK_END."
        exit 0
    fi

    echo "Found ${#ENTRY_FILES[@]} entry(s) for week $WEEK_NUM ($WEEK_START -> $WEEK_END)"

    TOTAL_TASKS=0; COMPLETED_TASKS=0; ROLLED_TASKS=0
    ENERGY_SUM=0; ENERGY_COUNT=0
    ALL_TAGS=""; ALL_WINS=""; ALL_STRUGGLES=""; ALL_LOGS=""

    for f in "${ENTRY_FILES[@]}"; do
        content=$(cat "$f")
        day_date=$(basename "$f" .md)
        day_name=$(head -1 "$f" | sed 's/.*-- //' 2>/dev/null || echo "$day_date")

        tasks=$(echo "$content" | grep -cE '^\s*- \[([ xX>])\]' || true)
        completed=$(echo "$content" | grep -cE '^\s*- \[[xX]\]' || true)
        rolled=$(echo "$content" | grep -cE '^\s*- \[>\]' || true)
        TOTAL_TASKS=$((TOTAL_TASKS + tasks))
        COMPLETED_TASKS=$((COMPLETED_TASKS + completed))
        ROLLED_TASKS=$((ROLLED_TASKS + rolled))

        energy_line=$(echo "$content" | grep -iE '^\*\*Energy \(1-10\):\*\*' || true)
        if [ -n "$energy_line" ]; then
            energy_val=$(echo "$energy_line" | sed 's/^\*\*Energy (1-10):\*\*//' | grep -oE '[0-9]+' | head -n1 || true)
            if [ -n "$energy_val" ] && [ "$energy_val" -ge 1 ] && [ "$energy_val" -le 10 ] 2>/dev/null; then
                ENERGY_SUM=$((ENERGY_SUM + energy_val)); ENERGY_COUNT=$((ENERGY_COUNT + 1))
            fi
        fi

        tags=$(echo "$content" | grep -oE '#[a-zA-Z0-9_-]+' || true)
        [ -n "$tags" ] && ALL_TAGS="$ALL_TAGS
$tags"

        wins=$(echo "$content" | sed -n '/^### Wins Today/,/^### /p' | tail -n +2 | grep -E '^[0-9]+\.' || true)
        [ -n "$wins" ] && ALL_WINS="$ALL_WINS
**$day_name**: $wins"

        struggles=$(echo "$content" | sed -n '/^### Struggles \/ Notes/,/^### /p' | tail -n +2 | grep -v '^$' | grep -v '^### ' || true)
        [ -n "$struggles" ] && ALL_STRUGGLES="$ALL_STRUGGLES
**$day_name**: $struggles"

        logs=$(echo "$content" | grep -E '^- [0-9]{2}:[0-9]{2} --' || true)
        [ -n "$logs" ] && ALL_LOGS="$ALL_LOGS
### $day_name
$logs"
    done

    [ $TOTAL_TASKS -gt 0 ] && TASK_RATE=$((COMPLETED_TASKS * 100 / TOTAL_TASKS)) || TASK_RATE=0
    [ $ENERGY_COUNT -gt 0 ] && ENERGY_AVG=$((ENERGY_SUM / ENERGY_COUNT)) || ENERGY_AVG="-"
    TOP_TAGS=$(echo "$ALL_TAGS" | tr ' ' '\n' | sort | uniq -c | sort -rn | head -n 5 | sed 's/^ *[0-9]* /- /' || true)

    HEADER=$(cat <<'EOF'
    _      _      _
 __(.)< __(.)> __(.)=
 \_)    \_)    \_)
EOF
)

    mkdir -p "$REPO_ROOT/reviews"
    REVIEW_FILE="$REPO_ROOT/reviews/$YEAR-W$WEEK_NUM.md"

    cat > "$REVIEW_FILE" <<EOF
# Week $WEEK_NUM Review -- $WEEK_START to $WEEK_END

$HEADER

## Snapshot

| Metric | Value |
|--------|-------|
| Days Journaled | ${#ENTRY_FILES[@]} / 7 |
| Tasks Completed | $COMPLETED_TASKS / $TOTAL_TASKS ($TASK_RATE%) |
| Tasks Rolled Over | $ROLLED_TASKS |
| Avg Energy | $ENERGY_AVG / 10 |

### Top Tags
$TOP_TAGS

---

## Wins This Week
$ALL_WINS

---

## Struggles / Patterns
$ALL_STRUGGLES

---

## Daily Logs
$ALL_LOGS

---

## Habit Check-In

*Run \`./scripts/journal habits --fill\` to auto-fill from daily entries.*

| Habit | Mon | Tue | Wed | Thu | Fri | Sat | Sun | Streak |
|-------|-----|-----|-----|-----|-----|-----|-----|--------|
| Exercise | | | | | | | | |
| Read | | | | | | | | |
| Meditate | | | | | | | | |
| Deep Work | | | | | | | | |
| Sleep 8h | | | | | | | | |

---

## Looking Ahead

- [ ] Priority for next week:
- [ ] Something to try differently:
- [ ] One thing to look forward to:

---

#weekly-review
EOF

    git add "$REVIEW_FILE"
    echo ""; echo "Week $WEEK_NUM review created: $REVIEW_FILE"
    echo ""; echo "Summary:"
    echo "  Days journaled: ${#ENTRY_FILES[@]}/7"
    echo "  Tasks: $COMPLETED_TASKS/$TOTAL_TASKS completed ($TASK_RATE%)"
    echo "  Rolled over: $ROLLED_TASKS"
    echo "  Avg energy: $ENERGY_AVG/10"
    [ -n "$TOP_TAGS" ] && { echo "  Top tags:"; echo "$TOP_TAGS" | sed 's/^/    /'; }
}

# ---------------------------------------------------------------------------
# habits - Tally habit streaks
# ---------------------------------------------------------------------------
cmd_habits() {
    FILL_REVIEW=false

    if [ "${1:-}" = "--fill" ] || [ "${1:-}" = "-f" ]; then
        FILL_REVIEW=true
        YEAR=$(date '+%Y'); MONTH=$(date '+%m')
    elif [ $# -ge 2 ]; then
        YEAR=$1; MONTH=$2
    else
        YEAR=$(date '+%Y'); MONTH=$(date '+%m')
    fi

    if ! echo "$MONTH" | grep -qE '^[0-9]{2}$'; then
        MONTH=$(printf "%02d" "$MONTH")
    fi

    month_name=$(date -d "$YEAR-$MONTH-01" '+%B' 2>/dev/null)
    [ -z "$month_name" ] && month_name=$(_J_month_name "$MONTH")

    MONTH_DIR="$REPO_ROOT/$YEAR/$MONTH-$(echo "$month_name" | tr '[:upper:]' '[:lower:]')"
    if [ ! -d "$MONTH_DIR" ]; then
        echo "No journal entries found for $month_name $YEAR."
        exit 0
    fi

    HABIT_NAMES=("Exercise" "Read" "Meditate" "Deep Work" "Sleep 8h")
    DAYS_IN_MONTH=$(date -d "$YEAR-$MONTH-01 + 1 month - 1 day" '+%d' 2>/dev/null)

    declare -A HABIT_COUNTS
    declare -A HABIT_STREAKS
    declare -A HABIT_CURRENT_STREAK
    for h in "${HABIT_NAMES[@]}"; do
        HABIT_COUNTS[$h]=0
        HABIT_STREAKS[$h]=0
        HABIT_CURRENT_STREAK[$h]=0
    done
    DAY_CHECKS=()

    for day in $(seq -w 1 $DAYS_IN_MONTH); do
        ENTRY_FILE="$MONTH_DIR/$YEAR-$MONTH-$day.md"
        day_checks_row=""
        if [ -f "$ENTRY_FILE" ]; then
            habits_section=$(sed -n '/^## Habits/,/^## /p' "$ENTRY_FILE" | head -n -1 || true)
            for h in "${HABIT_NAMES[@]}"; do
                if echo "$habits_section" | grep -qiE "^- \[[xX]\] +$h" 2>/dev/null; then
                    day_checks_row="${day_checks_row}| [x]"
                    HABIT_COUNTS[$h]=$((${HABIT_COUNTS[$h]} + 1))
                    HABIT_CURRENT_STREAK[$h]=$((${HABIT_CURRENT_STREAK[$h]} + 1))
                    if [ ${HABIT_CURRENT_STREAK[$h]} -gt ${HABIT_STREAKS[$h]} ]; then
                        HABIT_STREAKS[$h]=${HABIT_CURRENT_STREAK[$h]}
                    fi
                else
                    day_checks_row="${day_checks_row}| [ ]"
                    HABIT_CURRENT_STREAK[$h]=0
                fi
            done
        else
            for h in "${HABIT_NAMES[@]}"; do
                day_checks_row="${day_checks_row}| [ ]"
                HABIT_CURRENT_STREAK[$h]=0
            done
        fi
        DAY_CHECKS+=("$day_checks_row")
    done

    # Build monthly table
    MONTHLY_TABLE="# Habit Tracker -- $month_name $YEAR

| Habit"
    for day in $(seq -w 1 $DAYS_IN_MONTH); do
        day_num=$(echo "$day" | sed 's/^0//')
        MONTHLY_TABLE="$MONTHLY_TABLE | $day_num"
    done
    MONTHLY_TABLE="$MONTHLY_TABLE | Total | Streak |"

    MONTHLY_TABLE="$MONTHLY_TABLE
|-------"
    for day in $(seq 1 $DAYS_IN_MONTH); do
        MONTHLY_TABLE="$MONTHLY_TABLE|------"
    done
    MONTHLY_TABLE="$MONTHLY_TABLE|-------|--------|"

    idx=0
    for h in "${HABIT_NAMES[@]}"; do
        row="| $h"
        for check in "${DAY_CHECKS[@]}"; do
            habit_check=$(echo "$check" | cut -d'|' -f$((idx + 2)))
            row="$row$habit_check|"
        done
        count=${HABIT_COUNTS[$h]}
        streak=${HABIT_STREAKS[$h]}
        row="$row $count | $streak |"
        MONTHLY_TABLE="$MONTHLY_TABLE
$row"
        idx=$((idx + 1))
    done

    MONTHLY_TABLE="$MONTHLY_TABLE

*Auto-generated from daily journal entries.*"

    # Build weekly table (Mon-Sun)
    TODAY=$(date '+%Y-%m-%d')
    DOW=$(date -d "$TODAY" '+%u' 2>/dev/null)
    DAYS_BACK=$((DOW - 1))
    WEEK_START=$(date -d "$TODAY - $DAYS_BACK days" '+%Y-%m-%d' 2>/dev/null)

    WEEKLY_HEADER="| Habit | Mon | Tue | Wed | Thu | Fri | Sat | Sun | Streak |"
    WEEKLY_SEP="|-------|-----|-----|-----|-----|-----|-----|-----|--------|"
    WEEKLY_ROWS=""

    for h in "${HABIT_NAMES[@]}"; do
        row="| $h"
        week_counts=0; week_streak=0; current_run=0
        for i in $(seq 0 6); do
            CHECK_DATE=$(date -d "$WEEK_START + $i days" '+%Y-%m-%d' 2>/dev/null)
            cy=$(echo "$CHECK_DATE" | cut -d'-' -f1)
            cm=$(echo "$CHECK_DATE" | cut -d'-' -f2)
            cmonth=$(date -d "$CHECK_DATE" '+%B' 2>/dev/null)
            [ -z "$cmonth" ] && cmonth=$(_J_month_name "$cm")
            CHECK_FILE="$REPO_ROOT/$cy/$cm-$(echo "$cmonth" | tr '[:upper:]' '[:lower:]')/$CHECK_DATE.md"
            if [ -f "$CHECK_FILE" ]; then
                habits_section=$(sed -n '/^## Habits/,/^## /p' "$CHECK_FILE" | head -n -1 || true)
                if echo "$habits_section" | grep -qiE "^- \[[xX]\] +$h" 2>/dev/null; then
                    row="$row| [x]"
                    week_counts=$((week_counts + 1))
                    current_run=$((current_run + 1))
                    [ $current_run -gt $week_streak ] && week_streak=$current_run
                else
                    row="$row| [ ]"; current_run=0
                fi
            else
                row="$row| [ ]"; current_run=0
            fi
        done
        row="$row| $week_counts | $week_streak |"
        WEEKLY_ROWS="$WEEKLY_ROWS
$row"
    done

    WEEKLY_TABLE="$WEEKLY_HEADER
$WEEKLY_SEP$WEEKLY_ROWS"

    if [ "$FILL_REVIEW" = true ]; then
        REVIEW_DIR="$REPO_ROOT/reviews"
        if [ -d "$REVIEW_DIR" ]; then
            LATEST_REVIEW=$(ls -1t "$REVIEW_DIR"/*.md 2>/dev/null | head -n1 || true)
            if [ -n "$LATEST_REVIEW" ]; then
                REVIEW_CONTENT=$(cat "$LATEST_REVIEW")
                BEFORE=$(echo "$REVIEW_CONTENT" | sed -n '1,/^## Habit Check-In/p' | sed '$d')
                AFTER=$(echo "$REVIEW_CONTENT" | sed -n '/^\*Run \`\./,$p')
                [ -z "$AFTER" ] && AFTER=$(echo "$REVIEW_CONTENT" | sed -n '/^## Looking Ahead/,$p')
                NEW_CONTENT="$BEFORE
## Habit Check-In

*Auto-filled from daily entries.*

$WEEKLY_TABLE

$AFTER"
                echo "$NEW_CONTENT" > "$LATEST_REVIEW"
                git add "$LATEST_REVIEW"
                cat <<EOOUT
+---------------------------------------------------+
|              HABITS FILLED IN REVIEW               |
+---------------------------------------------------+
|  Review: $(basename "$LATEST_REVIEW")
|                                                   |
|  Weekly habit data injected successfully.         |
+---------------------------------------------------+
EOOUT
            else
                echo "No weekly review found. Outputting habit data:"
                echo "$WEEKLY_TABLE"
            fi
        else
            echo "No reviews directory. Outputting habit data:"
            echo "$WEEKLY_TABLE"
        fi
    else
        HABIT_FILE="$REPO_ROOT/$YEAR/$MONTH-$(echo "$month_name" | tr '[:upper:]' '[:lower:]')/habits.md"
        echo "$MONTHLY_TABLE" > "$HABIT_FILE"
        git add "$HABIT_FILE" 2>/dev/null || true
        echo "Habit tracker saved: $HABIT_FILE"
    fi

    echo ""
    echo "Summary for $month_name $YEAR:"
    for h in "${HABIT_NAMES[@]}"; do
        count=${HABIT_COUNTS[$h]}
        streak=${HABIT_STREAKS[$h]}
        echo "  $h: $count days, best streak: $streak"
    done
}

# ---------------------------------------------------------------------------
# remember - Resurface a random past entry
# ---------------------------------------------------------------------------
cmd_remember() {
    MIN_DAYS=30; MAX_DAYS=90

    if [ "${1:-}" = "--today" ] || [ "${1:-}" = "-t" ]; then
        TARGET_DATE=$(date -d "$(date '+%Y-%m-%d') - 1 year" '+%Y-%m-%d' 2>/dev/null)
        echo "This day last year: $TARGET_DATE"; echo ""
    else
        if [ $# -ge 2 ]; then MIN_DAYS=$1; MAX_DAYS=$2; fi
        SPAN=$((MAX_DAYS - MIN_DAYS))
        RANDOM_DAYS=$((MIN_DAYS + RANDOM % (SPAN + 1)))
        TARGET_DATE=$(date -d "$(date '+%Y-%m-%d') - $RANDOM_DAYS days" '+%Y-%m-%d' 2>/dev/null)
    fi

    y=$(echo "$TARGET_DATE" | cut -d'-' -f1); m=$(echo "$TARGET_DATE" | cut -d'-' -f2)
    month_name=$(date -d "$TARGET_DATE" '+%B' 2>/dev/null)
    [ -z "$month_name" ] && month_name=$(_J_month_name "$m")

    ENTRY_FILE="$REPO_ROOT/$y/$m-$(echo "$month_name" | tr '[:upper:]' '[:lower:]')/$TARGET_DATE.md"
    DAYS_AGO=$(( ($(date '+%s') - $(date -d "$TARGET_DATE" '+%s' 2>/dev/null)) / 86400 ))
    HEADER="+---------------------------------------------------+"

    if [ -f "$ENTRY_FILE" ]; then
        echo "$HEADER"
        printf "|         MEMORY FROM %3s DAYS AGO                |\n" "$DAYS_AGO"
        printf "|              %s                  |\n" "$TARGET_DATE"
        echo "$HEADER"; echo ""; cat "$ENTRY_FILE"; echo ""; echo "$HEADER"
    else
        echo "No journal entry found for $TARGET_DATE ($DAYS_AGO days ago)."
        echo ""; echo "Searching for nearby entries..."
        for offset in $(seq 1 7); do
            nearby=$(date -d "$TARGET_DATE - $offset days" '+%Y-%m-%d' 2>/dev/null)
            ny=$(echo "$nearby" | cut -d'-' -f1); nm=$(echo "$nearby" | cut -d'-' -f2)
            nmonth=$(date -d "$nearby" '+%B' 2>/dev/null)
            [ -z "$nmonth" ] && nmonth=$(_J_month_name "$nm")
            nearby_file="$REPO_ROOT/$ny/$nm-$(echo "$nmonth" | tr '[:upper:]' '[:lower:]')/$nearby.md"
            if [ -f "$nearby_file" ]; then
                echo ""; echo "$HEADER"
                printf "|   CLOSEST ENTRY FOUND: %s DAYS AGO              |\n" "$offset"
                printf "|              %s                  |\n" "$nearby"
                echo "$HEADER"; echo ""; cat "$nearby_file"; echo ""; echo "$HEADER"
                break
            fi
        done
    fi
}

# ---------------------------------------------------------------------------
# streak - Show journaling streaks
# ---------------------------------------------------------------------------
cmd_streak() {
    MODE="all"
    if [ "${1:-}" = "--month" ] || [ "${1:-}" = "-m" ]; then MODE="month"
    elif [ "${1:-}" = "--year" ] || [ "${1:-}" = "-y" ]; then MODE="year"; fi

    ALL_DATES=$(find "$REPO_ROOT" -type f -name '*.md' | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}\.md$' | sed 's/\.md$//' | sort)
    if [ -z "$ALL_DATES" ]; then echo "No journal entries found yet. Start journaling!"; exit 0; fi

    if [ "$MODE" = "month" ]; then
        CURRENT_MONTH=$(date '+%Y-%m')
        DATES=$(echo "$ALL_DATES" | grep "^$CURRENT_MONTH" || true)
        LABEL="This Month"
    elif [ "$MODE" = "year" ]; then
        CURRENT_YEAR=$(date '+%Y')
        DATES=$(echo "$ALL_DATES" | grep "^$CURRENT_YEAR" || true)
        LABEL="This Year"
    else
        DATES="$ALL_DATES"
        LABEL="All Time"
    fi

    if [ -z "$DATES" ]; then echo "No entries for $LABEL."; exit 0; fi

    TOTAL_ENTRIES=$(echo "$DATES" | wc -l | tr -d ' ')
    FIRST_DATE=$(echo "$DATES" | head -n1)

    TODAY=$(date '+%Y-%m-%d')
    YESTERDAY=$(date -d "$TODAY - 1 day" '+%Y-%m-%d' 2>/dev/null)

    CURRENT_STREAK=0; CHECK_DATE="$TODAY"
    if echo "$DATES" | grep -qx "$TODAY"; then CURRENT_STREAK=1
    elif echo "$DATES" | grep -qx "$YESTERDAY"; then CURRENT_STREAK=1; CHECK_DATE="$YESTERDAY"
    else CURRENT_STREAK=0; fi

    if [ $CURRENT_STREAK -gt 0 ]; then
        while true; do
            PREV=$(date -d "$CHECK_DATE - 1 day" '+%Y-%m-%d' 2>/dev/null)
            if echo "$DATES" | grep -qx "$PREV"; then
                CURRENT_STREAK=$((CURRENT_STREAK + 1)); CHECK_DATE="$PREV"
            else break; fi
        done
    fi

    LONGEST_STREAK=0; CURRENT_RUN=0; PREV_EPOCH=0
    for d in $(echo "$DATES" | sort); do
        THIS_EPOCH=$(date -d "$d" '+%s' 2>/dev/null)
        if [ $PREV_EPOCH -eq 0 ]; then CURRENT_RUN=1
        else
            DIFF=$(( (THIS_EPOCH - PREV_EPOCH) / 86400 ))
            if [ $DIFF -eq 1 ]; then CURRENT_RUN=$((CURRENT_RUN + 1))
            else
                [ $CURRENT_RUN -gt $LONGEST_STREAK ] && LONGEST_STREAK=$CURRENT_RUN
                CURRENT_RUN=1
            fi
        fi
        PREV_EPOCH=$THIS_EPOCH
    done
    [ $CURRENT_RUN -gt $LONGEST_STREAK ] && LONGEST_STREAK=$CURRENT_RUN

    DOW=$(date '+%u')
    DAYS_BACK=$((DOW - 1))
    WEEK_START=$(date -d "$(date '+%Y-%m-%d') - $DAYS_BACK days" '+%Y-%m-%d' 2>/dev/null)
    THIS_WEEK_COUNT=0
    for i in $(seq 0 6); do
        CHECK=$(date -d "$WEEK_START + $i days" '+%Y-%m-%d' 2>/dev/null)
        echo "$DATES" | grep -qx "$CHECK" && THIS_WEEK_COUNT=$((THIS_WEEK_COUNT + 1))
    done

    FIRE_7=""; FIRE_30=""; FIRE_100=""
    [ $CURRENT_STREAK -ge 7 ] && FIRE_7="[*]"
    [ $CURRENT_STREAK -ge 30 ] && FIRE_30="[*]"
    [ $CURRENT_STREAK -ge 100 ] && FIRE_100="[*]"

    if [ $CURRENT_STREAK -eq 0 ]; then FIRE_ART=$(cat <<'EOF'
        (    )
        )  (
      .'    '.
     /        \
    |          |
     \  ~  ~  /
      '.____.'
EOF
)
    elif [ $CURRENT_STREAK -lt 7 ]; then FIRE_ART=$(cat <<'EOF'
         )
        (  )
       .'  '.
      / ~  ~ \
     |        |
      \      /
       '....'
      /      \
     '________'
EOF
)
    elif [ $CURRENT_STREAK -lt 30 ]; then FIRE_ART=$(cat <<'EOF'
       .-(   )-.
      /         \
     |   ~   ~   |
     |           |
      \  .---.  /
       '-/   \-'
        /     \
       '-------'
      /         \
     '___________'
EOF
)
    else FIRE_ART=$(cat <<'EOF'
         (    )
         )  ( (
       .'   '. '.
      /  ~  ~  \
     |          |
     |  *    *  |
      \  \~~/  /
       '-.  .-'
      .-'    '-.
     /  .----.  \
    /  /      \  \
   '  '________'  '
   '______________'
EOF
); fi

    if [ "$MODE" = "all" ]; then cat <<EOF
$FIRE_ART
+---------------------------------------------------+
|                 JOURNAL STREAKS                    |
+---------------------------------------------------+
|  $LABEL                                           |
|                                                   |
|  Current Streak : $CURRENT_STREAK days
|  Longest Streak : $LONGEST_STREAK days
|  Total Entries  : $TOTAL_ENTRIES
|  First Entry    : $FIRST_DATE
|                                                   |
|  Milestones:                                      |
|    7-day streak  $FIRE_7                          |
|    30-day streak $FIRE_30                         |
|    100-day streak $FIRE_100                       |
|                                                   |
|  This Week      : $THIS_WEEK_COUNT / 7 days
+---------------------------------------------------+
EOF
    else cat <<EOF
$FIRE_ART
+---------------------------------------------------+
|                 JOURNAL STREAKS                    |
+---------------------------------------------------+
|  $LABEL                                           |
|                                                   |
|  Current Streak : $CURRENT_STREAK days
|  Total Entries  : $TOTAL_ENTRIES
|  This Week      : $THIS_WEEK_COUNT / 7 days
+---------------------------------------------------+
EOF
    fi
}

# ---------------------------------------------------------------------------
# setup - Enable Git hooks
# ---------------------------------------------------------------------------
cmd_setup() {
    echo "Enabling custom hooks for agenic-journal..."
    git config core.hooksPath "$REPO_ROOT/.githooks"
    chmod +x "$REPO_ROOT"/.githooks/*
    echo "Hooks enabled from: $REPO_ROOT/.githooks"
    echo ""
    echo "Active hooks:"
    ls -1 "$REPO_ROOT"/.githooks/
}

# ---------------------------------------------------------------------------
# help - Show usage
# ---------------------------------------------------------------------------
cmd_help() {
    cat <<'EOF'
    _      _      _
 __(.)< __(.)> __(.)=
 \_)    \_)    \_)

 agenic-journal -- unified CLI

 USAGE
   ./scripts/journal <command> [args...]

 COMMANDS
   new [YYYY-MM-DD]              Create today's entry (or specific date)
   log "NOTE" [-d DATE] [-t TAG] [-n]  Append a timestamped note
   rollover [YYYY-MM-DD]         Roll unchecked tasks from yesterday (or date)
   review [YYYY-MM-DD]           Generate weekly review (current or from date)
   habits [YYYY MM | --fill]     Tally habit streaks (monthly) or fill review
   remember [MIN MAX | --today]  Resurface random entry (30-90 days default)
   streak [--month | --year]     Show journaling streak stats
   setup                         Enable Git hooks (run once after clone)
   help                          Show this help

 EXAMPLES
   ./scripts/journal new
   ./scripts/journal log "got lunch at panda express" -t win
   ./scripts/journal rollover
   ./scripts/journal review
   ./scripts/journal habits --fill
   ./scripts/journal remember --today
   ./scripts/journal streak

 SUNDAY RITUAL
   ./scripts/journal review && ./scripts/journal habits --fill && ./scripts/journal streak
EOF
}

# ---------------------------------------------------------------------------
# Main routing
# ---------------------------------------------------------------------------

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
    new)        cmd_new "$@" ;;
    log)        cmd_log "$@" ;;
    rollover)   cmd_rollover "$@" ;;
    review)     cmd_review "$@" ;;
    habits)     cmd_habits "$@" ;;
    remember)   cmd_remember "$@" ;;
    streak)     cmd_streak "$@" ;;
    setup)      cmd_setup "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
        echo "Unknown command: $COMMAND"
        echo "Run './scripts/journal help' for usage."
        exit 1
        ;;
esac
